    if Noclip then
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
        for _, motor in pairs(workspace:GetChildren()) do
            if motor.Name:find(player.Name) then
                for _, p in pairs(motor:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
        end
    end
end)

local function AutoRace()
    -- 1. Tween Character ke Start
    print("Tweening to Start...")
    local distStart = (root.Position - StartHitbox.Position).Magnitude
    tweenTo(char, StartHitbox, distStart/100)

    -- 2. Spawn Motor dengan Delay Load
    ReplicatedStorage.SpawnCarEvents.DespawnCar:FireServer()
    task.wait(0.5)
    ReplicatedStorage.SpawnCarEvents.SpawnCar:FireServer("Yamahax-MioSporty")
    
    print("Motor Spawned, waiting 3s for load...")
    task.wait(3) -- Delay tambahan supaya motor keload sempurna

    local motorModel = nil
    repeat
        for _, v in pairs(workspace:GetChildren()) do
            if v.Name:find(player.Name) and v.Name:find("Montors") then
                motorModel = v
                break
            end
        end
        task.wait(0.5)
    until motorModel

    -- 3. Tween ke Motor & Duduk
    print("Approach Motor...")
    local seat = motorModel:WaitForChild("DriveSeat")
    local prompt = seat:WaitForChild("ProximityPrompt")
    local distToMotor = (root.Position - seat.Position).Magnitude
    tweenTo(char, seat.CFrame, distToMotor/50)
    
    repeat
        fireproximityprompt(prompt)
        task.wait(0.3)
    until hum.Sit

    -- 4. Delay Bypass 34 Detik
    print("Waiting 34s Bypass...")
    task.wait(34)

    -- 5. Racing Start
    workspace.Gravity = 0
    Noclip = true
    
    for i, cp in ipairs(Route) do
        -- A. Tween ke Koordinat Target
        local dist = (motorModel:GetPivot().Position - cp.pos.Position).Magnitude
        print("Targeting: " .. cp.id)
        tweenTo(motorModel, cp.pos, dist/Speed)

        -- B. DOUBLE-TAP METHOD
        local overshoot = cp.pos * CFrame.new(0, 0, -5) 
        tweenTo(motorModel, overshoot, 0.1) 
        tweenTo(motorModel, cp.pos, 0.1)

        if i == 19 then
            -- 6. Finish Logic
            Noclip = false
            workspace.Gravity = 196
            for _, p in pairs(motorModel:GetDescendants()) do
                if p:IsA("BasePart") then p.Anchored = true end
            end
            task.wait(0.2)
            hum.Jump = true
            task.wait(0.5)
            ReplicatedStorage.SpawnCarEvents.DespawnCar:FireServer()
            print("Loop Done.")
            break
        end
    end
end

while true do
