-- Fungsi Notifikasi Tunggal saat delay dimulai
local function kirimNotif(pesan)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "Auto Minigame",
            Text = pesan,
            Duration = 4,
            Button1 = "OK"
        })
    end)
end

-- [FIXED]: Memindahkan MODEL TRUK, bukan karakter, biar ga pental (fling)
local function autoLoadSapiSpawn(modelTruk)
    if modelTruk and modelTruk:IsA("Model") then
        -- Pindahin truknya balik ke koordinat sapi spawn
        modelTruk:PivotTo(CFrame.new(-3386.31543, -79.0189896, -23828.9395))
        kirimNotif("Autofarm: Memindahkan Truk ke Sapi Spawn agar area ke-load!")
    end
end

