  -- Fungsi Cari Mobil
local function getMyVehicle()
    local vehiclesFolder = workspace:FindFirstChild("Vehicles")
    if vehiclesFolder then
        local targetName = player.Name .. "Car"
        local car = vehiclesFolder:FindFirstChild(targetName)
        if car then return car end
        for _, v in pairs(vehiclesFolder:GetChildren()) do
            if v:IsA("Model") and string.find(v.Name, player.Name) then return v end
        end
    end
    return nil
end

-- Logic Tween (Speed 200 + No Void)
local function tweenToPosition(car, startCFrame, endCFrame)
    local distance = (startCFrame.Position - endCFrame.Position).Magnitude
    local duration = distance / _G.TweenSpeed
    local tweenValue = Instance.new("CFrameValue")
    tweenValue.Value = startCFrame
    
    local connection = tweenValue.Changed:Connect(function()
        car:PivotTo(tweenValue.Value * CFrame.new(0, 1.2, 0))
    end)

    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(tweenValue, tweenInfo, {Value = endCFrame})
    
    workspace.Gravity = 0
    tween:Play()
    tween.Completed:Wait()
    workspace.Gravity = 196
    
    connection:Disconnect()
    tweenValue:Destroy()
end

-- Loop Auto Race
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.AutoRaceActive then
            local car = getMyVehicle()
            local folder = workspace:FindFirstChild("Etc") and workspace.Etc:FindFirstChild("Race") and workspace.Etc.Race:FindFirstChild("Checkpoint")
            
            if car and folder then
                for i = 1, 38 do
                    if not _G.AutoRaceActive then break end
                    local targetCP = folder:FindFirstChild(tostring(i))
                    if targetCP then
                        tweenToPosition(car, car:GetPivot(), targetCP:GetPivot())
                        task.wait(_G.TweenDelay) -- Jeda 2 detik biar CP kedaftar
                    end
                end
                -- Finish Line
                if _G.AutoRaceActive then
                    local finishCP = folder:FindFirstChild("Finish")
                    if finishCP then
                        tweenToPosition(car, car:GetPivot(), finishCP:GetPivot())
                        task.wait(5) -- Nunggu PTS
                    end
                end
                _G.AutoRaceActive = false
            end
        end
    end
end)
                          
