-- --- LOOP MONITORING ---
task.spawn(function()
    while task.wait(1) do
        if UangLabel and StatsFolder then
            pcall(function()
                local currentUang = StatsFolder.Uang.Value
                UangLabel:SetContent(formatRS(currentUang))
                EarningLabel:SetContent(formatRS(currentUang - StartUang))
                
                local diff = os.time() - StartTime
                local h, m, s = math.floor(diff/3600), math.floor((diff%3600)/60), diff%60
                TimeLabel:SetContent(string.format("%02d:%02d:%02d", h, m, s))
                
                local ping = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValueString():split(" ")[1]
                PingLabel:SetContent(math.floor(tonumber(ping) or 0) .. " ms")
                
                local fps = math.floor(1/task.wait())
                FPSLabel:SetContent(tostring(fps) .. " FPS")
            end)
        end
    end
end)
