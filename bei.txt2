local VelarisUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/nhfudzfsrzggt/brigida/refs/heads/main/dist/main.lua", true))()


-- Services
local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local RS = game:GetService("ReplicatedStorage")
local Remotes = RS:WaitForChild("Remotes")
local VirtualUser = game:GetService("VirtualUser")

-- FIX DATA FOLDER (Pake PlayerData sesuai kode lama lu yang work)
local PlayerData = LP:WaitForChild("PlayerData", 10)
local StatsFolder = PlayerData -- Re-alias biar gak perlu ganti nama variabel di bawah
local OwnedCarsFolder = PlayerData:WaitForChild("OwnedCars", 10)

-- FIX CAR DATA (Pake InvokeServer sesuai kode lama)
local CarData = Remotes.GetClientCustomizationData:InvokeServer()

-- Data Binding
local StartTime = os.time()
-- Cek uang di dalam PlayerData
local StartUang = (StatsFolder and StatsFolder:FindFirstChild("Uang")) and StatsFolder.Uang.Value or 0
local lastTarget, jobStarted, noBillboardTime = nil, false, 0
local busOptions = {}
_G.SelectedBus = "" 
_G.AutoFull = false
_G.AntiAFK = true
TargetUang = 0

-- Forward Declaration Labels (Biar bisa diupdate dari fungsi manapun)
local StatusLabel, UangLabel, EarningLabel, TimeLabel, FPSLabel, PingLabel

-- --- FORMAT RUPIAH ---
local function formatRS(amount)
    local formatted = tostring(amount)
    while true do  
        local k
        formatted, k = string.gsub(formatted, "^(-?%d+)(%d%d%d)", '%1.%2')
        if (k==0) then break end
    end
    return "Rp " .. formatted
end

-- --- SCANNING BUS ---
pcall(function()
    for _, car in pairs(OwnedCarsFolder:GetChildren()) do
        table.insert(busOptions, car.Name)
    end
end)

if #busOptions == 0 then table.insert(busOptions, "Jetbus_3_RM_SHD") end
_G.SelectedBus = busOptions[1]

-- --- UTILITY FUNCTIONS ---
local function SetStatus(text)
    if StatusLabel then
        StatusLabel:Set({ Title = "Status", Content = text })
    end
end

local function GetMyBus()
    -- Cek di folder mana bus kamu spawn biasanya (workspace.Vehicles atau sejenisnya)
    return workspace:FindFirstChild("SpawnedVehicles") and workspace.SpawnedVehicles:FindFirstChild(_G.SelectedBus) or workspace:FindFirstChild(_G.SelectedBus)
end

local function SetFreeze(state)
    local bus = GetMyBus()
    if bus then
        for _, part in pairs(bus:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = state
                if not state then
                    part.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end
            end
        end
    end
end

-- Anti-AFK
LP.Idled:Connect(function()
    if _G.AntiAFK then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end
end)


