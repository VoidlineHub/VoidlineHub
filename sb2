-- Function untuk scan otomatis Cooking Pot paling dekat dengan karakter
local function getClosestCookingPot()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local myPos = character.HumanoidRootPart.Position
    local closestPot = nil
    local shortestDistance = math.huge
    
    -- Looping semua path yang lu kasih buat nyari objek bernama "Cooking Pot"
    for _, folder in pairs(HousePaths) do
        if folder then
            for _, child in pairs(folder:GetChildren()) do
                if child.Name == "Cooking Pot" and child:IsA("BasePart") or child:IsA("Model") then
                    -- Cari primary part atau part utama dari Cooking Pot untuk hitung jarak
                    local potPart = child:IsA("BasePart") and child or child:FindFirstChildWhichIsA("BasePart")
                    if potPart then
                        local distance = (myPos - potPart.Position).Magnitude
                        if distance < shortestDistance then
                            shortestDistance = distance
                            closestPot = child
                        end
                    end
                end
            end
        end
    end
    return closestPot
end

-- Function Notifikasi Roblox Bawaan
local function sendNotification(title, text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title;
            Text = text;
            Duration = 3;
        })
    end)
end

-- Function Sederhana untuk Equip Item langsung ke Character
local function equipItem(itemName)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    
    if character and character:FindFirstChild(itemName) then
        return true
    end
    
    if backpack then
        local item = backpack:FindFirstChild(itemName)
        if item then
            item.Parent = character
            task.wait(0.4)
            return true
        end
    end
    return false
end

-- Function Wait Timer sampai teksnya menunjukkan angka 0 (Dinamis berdasarkan pot terdekat)
local function waitTimerToZero(timerLabel)
    if not timerLabel then return end
    repeat
        task.wait(0.1)
    until not _G.Autofarm or timerLabel.Text == "0" or timerLabel.Text == "0s" or string.match(timerLabel.Text, "^0")
end

-- Main Loop Autofarm dengan Auto-Deteksi Jarak Terdekat
task.spawn(function()
    while true do
        if _G.Autofarm then
            -- Cari Cooking Pot terdekat di awal setiap siklus baru
            local currentPot = getClosestCookingPot()
            
            if not currentPot then
                sendNotification("Autofarm Error", "Cooking Pot terdekat tidak ditemukan! Dekati Pot dulu.")
                _G.Autofarm = false
                task.wait(1)
            else
                -- Set referensi prompt dan timer dari pot terdekat yang berhasil dideteksi
                local prompt = currentPot:FindFirstChild("Attachment") and currentPot.Attachment:FindFirstChild("ProximityPrompt") or currentPot:FindFirstChildWhichIsA("ProximityPrompt", true)
                local timerLabel = currentPot:FindFirstChild("Timer") and currentPot.Timer:FindFirstChild("TextLabel") or currentPot:FindFirstChild("TextLabel", true)
                
                if not prompt or not timerLabel then
                    sendNotification("Autofarm Error", "Struktur Prompt/Timer Pot tidak cocok!")
                    _G.Autofarm = false
                else
                    -- STEP 1: Pertama pegang Water dan jalankan prompt
                    if _G.Autofarm then
                        local hasWater = equipItem("Water")
                        if hasWater then
                            fireproximityprompt(prompt)
                            -- AKALIN ANTI-CHEAT VISUAL TIMER 20: Delay 4 detik setelah taruh water
                            task.wait(4)
                        else
                            sendNotification("Autofarm Info", "Water tidak ditemukan!")
                            _G.Autofarm = false
                        end
                    end

                    -- STEP 2: Setelah nunggu delay 4 detik, baru pantau timer 20 sampai bener-bener jadi 0
                    if _G.Autofarm then
                        waitTimerToZero(timerLabel)
                        task.wait(0.5)
                    end

                    -- STEP 3: Setelah timer 20 jadi 0, BARU taruh Sugar Block Bag
                    if _G.Autofarm then
                        local hasSugar = equipItem("Sugar Block Bag")
                        if hasSugar then
                            fireproximityprompt(prompt)
                            task.wait(3) -- Jeda 3 detik sebelum masuk ke item berikutnya sesuai instruksi lu
                        else
                            sendNotification("Autofarm Info", "Sugar Block Bag tidak ditemukan!")
                            _G.Autofarm = false
                        end
                    end

                    -- STEP 4: Setelah delay 3 detik, BARU taruh Gelatin
                    if _G.Autofarm then
                        local hasGelatin = equipItem("Gelatin")
                        if hasGelatin then
                            fireproximityprompt(prompt)
                            -- AKALIN ANTI-CHEAT VISUAL TIMER 45: Delay 4 detik setelah taruh gelatin
                            task.wait(4)
                        else
                            sendNotification("Autofarm Info", "Gelatin tidak ditemukan!")
                            _G.Autofarm = false
                        end
                    end

                    -- STEP 5: Setelah nunggu delay 4 detik, baru pantau timer masak 45 sampai habis jadi 0
                    if _G.Autofarm then
                        waitTimerToZero(timerLabel)
                        task.wait(0.5)
                    end

                    -- STEP 6: Begitu timer 45 habis jadi 0, pegang Empty Bag buat ambil hasil masakannya
                    if _G.Autofarm then
                        local hasEmptyBag = equipItem("Empty Bag")
                        if hasEmptyBag then
                            fireproximityprompt(prompt)
                            task.wait(1.5) -- Kasih jeda sedikit sebelum siklusnya keulang lagi dari awal (Water)
                        else
                            sendNotification("Autofarm Info", "Empty Bag tidak ditemukan!")
                            _G.Autofarm = false
                        end
                    end
                end
            end
        end

        task.wait(0.5)
    end
end)

-- Function Pembelian di Store (Tetap dipisah aman dengan delay 2 detik)
local function buyIngredients(count)
    if count <= 0 then 
        sendNotification("Store Info", "Masukkan jumlah item yang valid dulu!")
        return 
    end
    
    sendNotification("Store Info", "Memulai pembelian barang... Diam di tempat store!")
    
    for i = 1, count do
        StorePurchase:FireServer("Gelatin")
        task.wait(0.9)
    end
    
    for i = 1, count do
        StorePurchase:FireServer("Water")
        task.wait(0.9)
    end
    
    for i = 1, count do
        StorePurchase:FireServer("Sugar Block Bag")
        task.wait(0.9)
    end
    sendNotification("Store Info", "Semua bahan berhasil dibeli rata!")
end

