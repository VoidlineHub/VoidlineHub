local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")

local LocalPlayer = Players.LocalPlayer

-- TOGGLE & STATUS UTAMA
_G.AutoFarmSapi = true  -- Ubah ke false untuk mematikan farm
local sedangKerja = false -- Pengaman agar tidak TP ke sapi lain saat proses minigame/nganter

local function print(...)
    local argumen = {...}
    local pesan = ""
    for i, v in ipairs(argumen) do
        pesan = pesan .. tostring(v) .. " "
    end
    
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = " Auto Minigame",
            Text = pesan,
            Duration = 4,
            Button1 = "OK"
        })
    end)
end

local QurbanRemotes = ReplicatedStorage:WaitForChild("EventAsset"):WaitForChild("QurbanRemotes")
local StartLoadingMinigame = QurbanRemotes:WaitForChild("StartLoadingMinigame")
local PromptInput = QurbanRemotes:WaitForChild("PromptInput")
local DestinationRevealed = QurbanRemotes:WaitForChild("DestinationRevealed")

print("Script Aktif")

---------------------------------------------------------------------
-- FUNGSI MENCARI SAPI DI WORKSPACE
---------------------------------------------------------------------
local function getAllCows()
    local validCows = {}
    for _, obj in pairs(workspace:GetChildren()) do
        if string.sub(obj.Name, 1, 4) == "Cow_" and obj:IsA("Model") then
            table.insert(validCows, obj)
        end
    end
    return validCows
end

---------------------------------------------------------------------
-- FUNGSI UTAMA UNTUK TP DAN FIRE PROMPT KE SAPI RANDOM
---------------------------------------------------------------------
local function harvestSingleCow()
    local cows = getAllCows()
    
    if #cows == 0 then
        print("Gak ada sapi ditemukan di workspace!")
        return false
    end

    -- 1. Pilih 1 sapi acak
    local randomCow = cows[math.random(1, #cows)]
    print("Menuju ke Sapi -> " .. randomCow.Name)

    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    
    if hrp then
        -- 2. Cari part utama sapi (Mendukung tipe biasa, mutasi, maupun giant via recursive)
        local targetPart = randomCow:FindFirstChild("Cow_F_LOD1_Cow_F_0", true) or randomCow:FindFirstChildWhichIsA("BasePart", true)
        
        if targetPart then
            -- Lock status agar tidak mencari sapi lain saat proses eksekusi
            sedangKerja = true
            
            -- 3. Teleport ke target sapi
            hrp.CFrame = targetPart.CFrame * CFrame.new(0, 3, 0)
            
            -- 4. Tunggu objek ke-load sempurna di client (StreamingEnabled Bypass)
            task.wait(0.6)
            
            -- 5. Cari ProximityPrompt
            local prompt = randomCow:FindFirstChild("LoadPrompt", true) or randomCow:FindFirstChildWhichIsA("ProximityPrompt", true)
            
            if prompt then
                print("Prompt ditemukan, memerah sapi...")
                fireproximityprompt(prompt)
                
                -- Pengaman Anti-Stuck: Jika dalam 15 detik minigame/rute tidak ketrigger, lepas lock
                task.delay(15, function()
                    if sedangKerja then
                        local humanoid = character:FindFirstChildOfClass("Humanoid")
                        if humanoid and not humanoid.SeatPart then
                            print("⚠️ Deteksi stuck/gagal load minigame, mereset target...")
                            sedangKerja = false
                        end
                    end
                end)
                
                return true
            else
                print("LoadPrompt gagal dimuat di lokasi ini.")
                sedangKerja = false
                return false
            end
        end
    end
    return false
end

---------------------------------------------------------------------
-- LOGIKA AUTO ANSWER MINIGAME
---------------------------------------------------------------------
StartLoadingMinigame.OnClientEvent:Connect(function(data)
    if not _G.AutoFarmSapi then return end
    if not data or not data.sequence then return end
    
    sedangKerja = true -- Kunci posisi aman selama minigame berlangsung
    print("Minigame dimulai: " .. tostring(data.animalType))
    task.wait(1.0) 

    for index, prompt in ipairs(data.sequence) do
        local kunciJawaban = nil

        if prompt.type == "TAP" then
            kunciJawaban = prompt.key
        elseif prompt.type == "MASH" then
            kunciJawaban = prompt.targetCount
        elseif prompt.type == "SEQUENCE" then
            kunciJawaban = prompt.sequence
        end

        if kunciJawaban ~= nil then
            PromptInput:FireServer({
                ["promptIndex"] = index,
                ["input"] = kunciJawaban
            })
            print("Sukses tahap: " .. tostring(index))
        end

        task.wait(math.random(80, 120) / 100) 
    end
end)

---------------------------------------------------------------------
-- LOGIKA TELEPORT TRUK & HITUNG MUNDUR ROUTE DELIVER
---------------------------------------------------------------------
DestinationRevealed.OnClientEvent:Connect(function(data)
    if not _G.AutoFarmSapi then return end
    if not data or not data.masjidPosition then return end
    
    local karakter = LocalPlayer.Character
    if not karakter then return end
    
    local humanoid = karakter:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    sedangKerja = true -- Tetap kunci status agar aman selama proses nganter
    print("Lokasi diterima")
    
    -- 1. TUNGGU SAMPAI KAMU DUDUK
    while not humanoid.SeatPart do
        task.wait(0.5)
    end
    
    print("Mengecek jarak tujuan...")
    task.wait(1) 
    
    local waktuTunggu = 20 
    
    -- 2. LOGIKA CEK TEXT DISTANCE DI GUI
    pcall(function()
        local playerGui = LocalPlayer:WaitForChild("PlayerGui", 5)
        local deliveryHUD = playerGui and playerGui:WaitForChild("DeliveryHUD", 5)
        local destFrame = deliveryHUD and deliveryHUD:WaitForChild("DestinationFrame", 5)
        local distanceLabel = destFrame and destFrame:WaitForChild("Distance", 5)
        
        if distanceLabel then
            local teksJarak = string.lower(distanceLabel.Text)
            print("Deteksi teks jarak di UI: " .. teksJarak)
            
            if not string.find(teksJarak, "k") then
                waktuTunggu = 65 
                print("Menggunakan delay jauh detik agar poin masuk")
            else
                waktuTunggu = 20 
                print("menggunakan delay aman detik.")
            end
        end
    end)
    
    -- 3. PROSES HITUNG MUNDUR DELAY
    print("Menahan posisi selama " .. tostring(waktuTunggu) .. " detik...")
    task.wait(waktuTunggu)
    
    -- 4. MENCARI MODEL TRUK DI VEHICLES
    local modelTruk = nil
    local vehiclesFolder = workspace:FindFirstChild("Vehicles")
    
    if vehiclesFolder then
        for _, v in ipairs(vehiclesFolder:GetChildren()) do
            if string.sub(v.Name, 1, 11) == "QurbanTruck" then
                modelTruk = v
                break
            end
        end
    end
    
    if not modelTruk and humanoid.SeatPart then
        modelTruk = humanoid.SeatPart:FindFirstAncestorOfClass("Model")
    end
    
    if not modelTruk then 
        print("❌ Gagal teleport, model truk tidak terdeteksi!")
        sedangKerja = false -- Reset status agar bisa cari sapi lain jika gagal total
        return 
    end
    
    -- 5. EKSEKUSI TELEPORTASI MODEL VIA PIVOT TO
    print("Memindahkan model truk ke tujuan...")
    
    local pivotAwal = modelTruk:GetPivot()
    local posisiTujuan = data.masjidPosition + Vector3.new(0, 5, 0)
    local cframeTujuan = CFrame.new(posisiTujuan) * pivotAwal.Rotation
    
    modelTruk:PivotTo(cframeTujuan)
    print("Alhamdulillah, truk berhasil sampai dan poin aman!")
    
    -- 6. BERES NGANTER, RESET STATUS BIAR BISA CARI SAPI LAGI
    task.wait(2.0) -- Kasih jeda 2 detik biar data di server kelar kesinkronisasi
    sedangKerja = false 
end)

