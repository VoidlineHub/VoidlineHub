-- LOOPING AUTO FARM (BERJALAN DI BACKGROUND)
---------------------------------------------------------------------
task.spawn(function()
    while task.wait(0.5) do
        if _G.AutoFarmSapi and not sedangKerja then
            local karakter = LocalPlayer.Character
            local humanoid = karakter and karakter:FindFirstChildOfClass("Humanoid")
            
            -- Jalankan pencarian jika karakter sedang TIDAK berada di dalam truk
            if humanoid and not humanoid.SeatPart then
                harvestSingleCow()
            end
        end
    end
end)

