        task.wait(1.5) -- Jeda lebih lama biar server siap
        pcall(function()
            local currentRace = lp:GetAttribute("RaceName") or "AirportDrag"
            remotes.Race_SkipVote:FireServer(currentRace)
            
        end)
    end
end)

