-- [[ VOIDLINE HUB - SAFE 17S FAST EDITION ]] --
local WindUI = loadstring(game:HttpGet('https://github.com/Footagesus/WindUI/releases/latest/download/main.lua'))()

-- [[ DATA BINDING ]] --
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local lp = Players.LocalPlayer
local remotes = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Races")

-- [[ VARIABEL ]] --
_G.AutoFarm = false
_G.SelectedRace = "Airport Drag"

local raceNames = {"Airport Drag", "Tail of the Dragon"}
local TAIL_FINISH = CFrame.new(66.1744461, 97.5540085, -6510.10059)
local FINISH_POS = CFrame.new(16376.9463, 12.8355455, -1365.27478, -0.906296611, 0, 0.422642082, 0, 1, 0, -0.422642082, 0, -0.906296611)
local DashBtn

-- [[ FUNCTION ]] --
local function getMyCar()
    return workspace.AVehicleStorage:FindFirstChild(lp.Name)
end

local function joinRace()
    if not _G.AutoFarm then return end
    local mode = (_G.SelectedRace == "Tail of the Dragon" and "Tail") or "AirportDrag"
    remotes.Race_Join:FireServer(mode)
end

-- [[ LOGIC RACE ]] --
remotes.Race_TimerStart.OnClientEvent:Connect(function(trackName, startTime, cpCount)
    if not _G.AutoFarm then return end
    
    while workspace:GetServerTimeNow() < startTime do 
        if DashBtn then DashBtn:SetDesc("Status: Waiting Green Light...") end
        task.wait(0.01) 
    end
    
    -- [[ TAIL LOGIC (ASLI LU) ]] --
    if _G.SelectedRace == "Tail of the Dragon" and trackName == "Tail" then
        for i = 1, 95 do
            if not _G.AutoFarm then break end
            if DashBtn then DashBtn:SetDesc("Timer: " .. i .. "s / 95s") end
            task.wait(1)
        end
        local car = getMyCar()
        if car then
            car:PivotTo(TAIL_FINISH) 
            task.wait(3)
            local raceFolder = workspace:FindFirstChild("Races")
            local map = raceFolder and raceFolder.Tail:FindFirstChild("TailMap")
            if map then
                for i = 1, 32 do
                    if not _G.AutoFarm then break end
                    local cp = map.Checkpoints:FindFirstChild(tostring(i))
                    if cp then 
                        DashBtn:SetDesc("CP: " .. i .. "/32")
                        car:PivotTo(cp.CFrame + Vector3.new(0, 2, 0))
                        task.wait(0.4) 
                    end
                end
                car:PivotTo(TAIL_FINISH)
            end
        end
        
    -- [[ DRAG LOGIC (17S TOTAL: 5+5+3+4) ]] --
    elseif _G.SelectedRace == "Airport Drag" and trackName ~= "Tail" then
        local car = getMyCar()
        local map = workspace:WaitForChild("Races"):WaitForChild("AirportDrag"):WaitForChild("AirportDragMap")
        local cps = map:WaitForChild("Checkpoints")

        -- CP 1: Delay 5s
        DashBtn:SetDesc("Status: Delay CP 1 (5s)")
        task.wait(5)
        local cp1 = cps:WaitForChild("1", 5)
        if cp1 and car then car:PivotTo(cp1.CFrame + Vector3.new(0, 2, 0)) end

        -- CP 2: Delay 5s
        DashBtn:SetDesc("Status: Delay CP 2 (5s)")
        task.wait(5)
        local cp2 = cps:WaitForChild("2", 5)
        if cp2 and car then car:PivotTo(cp2.CFrame + Vector3.new(0, 2, 0)) end

        -- CP 3: Delay 3s
        DashBtn:SetDesc("Status: Delay CP 3 (3s)")
        task.wait(3)
        local cp3 = cps:WaitForChild("3", 5)
        if cp3 and car then car:PivotTo(cp3.CFrame + Vector3.new(0, 2, 0)) end

        -- FINISH: Delay 4s (Total 17s)
        DashBtn:SetDesc("Status: Final Delay (4s)")
        task.wait(4)
        if car then
            car:PivotTo(FINISH_POS)
            DashBtn:SetDesc("Status: Done (Safe 17s)")
        end
    end
end)

-- [[ REJOIN & SKIP ]] --
remotes.Race_Finish.OnClientEvent:Connect(function()
    if not _G.AutoFarm then return end
    for i = 9, 1, -1 do
        DashBtn:SetDesc("Re-join in: " .. i .. "s")
        task.wait(1)
    end
    joinRace()
end)

remotes.Race_SkipCutscene.OnClientEvent:Connect(function()
    if _G.AutoFarm then
        task.wait(2)
        local mode = (_G.SelectedRace == "Tail of the Dragon" and "Tail") or "AirportDrag"
        remotes.Race_SkipVote:FireServer(mode)
    end
end)

-- [[ WINDOW & UI ]] --
local Window = WindUI:CreateWindow({
    Title = "VoidlineHub",
    Icon = "rbxassetid://10723343321",
    Author = "Bilzz",
    Size = UDim2.fromOffset(320, 380), 
    Transparent = true, 
    Folder = "VoidlineHub_Config"
})

local MainTab = Window:Tab({ Title = "Race Farm", Icon = "flag" })

MainTab:Section({ Title = "Live dashboard" })
DashBtn = MainTab:Button({
    Title = "Info Race",
    Desc = "Status: Idle",
    Callback = function() end
})

MainTab:Section({ Title = "auto race" })
MainTab:Dropdown({
    Title = "Select Race",
    Values = raceNames,
    Value = _G.SelectedRace,
    Callback = function(option) 
        _G.SelectedRace = option 
        DashBtn:SetDesc("Selected: " .. option)
    end
})

MainTab:Toggle({
    Title = "Enable Auto Race",
    Value = false,
    Callback = function(v)
        _G.AutoFarm = v
        if v then joinRace() end
    end
})

