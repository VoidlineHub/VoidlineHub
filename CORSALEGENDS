    Icon = "flag",
    Transparent = true
})

local MainTab = Window:Tab({ Title = "Main", Icon = "house" })
local MonitorTab = Window:Tab({ Title = "Monitor", Icon = "activity" })

-- MAIN TAB
MainTab:Section({ Title = "Auto Race Configuration" })
MainTab:Dropdown({
    Title = "Select Race",
    Desc = "Choose your racing mode!",
    Values = raceNames,
    Value = _G.SelectedRace,
    Callback = function(v) _G.SelectedRace = v end
})
MainTab:Toggle({
    Title = "Enable Auto Race",
    Desc = "Turn on your autorace!!", 
    Callback = function(v) _G.AutoFarm = v if v then joinRace() end end
})

MainTab:Section({ Title = "Auto Gacha System" })
MainTab:Dropdown({
    Title = "Crate Type",
    Desc = "Select your crate",
    Values = {"Import", "Part", "Fusion"},
    Value = "Import",
    Callback = function(v) _G.SelectedCrate = v end
})
MainTab:Input({
    Title = "Open Amount",
    Desc = "Can be 1, 5, 10",
    Placeholder = "Example: 10",
    Callback = function(v) _G.BuyAmount = tonumber(v) or 1 end
})
MainTab:Toggle({
    Title = "Enable Auto Gacha",
    Desc = "Turn on your gacha",
    Callback = function(v)
        _G.AutoGacha = v
        task.spawn(function()
            while _G.AutoGacha do
                local r = (_G.SelectedCrate == "Part" and "PC") or (_G.SelectedCrate == "Fusion" and "FC") or "IC"
                local targetRemote = remotes:FindFirstChild(r)
                if targetRemote then targetRemote:InvokeServer(_G.BuyAmount) end
                task.wait(2)
            end
        end)
    end
})

-- MONITOR TAB
MonitorTab:Section({ Title = "Discord Webhook" })
MonitorTab:Input({
