    Desc= "Webhook Logs",
    Placeholder = "Paste your webhook URL...",
    Callback = function(v) 
        _G.WebhookURL = v 
        if _G.WebhookEnabled and v ~= "" then sendWebhook("Webhook Connected!") end
    end
})
MonitorTab:Toggle({
    Title = "Enable Webhook Logs",
    Desc = "Turn on your Webhook",
    Callback = function(v) _G.WebhookEnabled = v end
})

