-- [[ DATA CONFIG ]] --
local FINISH_POS = CFrame.new(16376.9463, 12.8355455, -1365.27478, -0.906296611, 0, 0.422642082, 0, 1, 0, -0.422642082, 0, -0.906296611)
local TAIL_FINISH = CFrame.new(66.1744461, 97.5540085, -6510.10059)
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local lp = Players.LocalPlayer
local remotes = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Races")


-- [[ VARIABEL ]] --
_G.AutoTail = false
_G.AutoFarm = false

-- [[ TAIL RACE LOGIC ]] --
RaceRemotes.Race_TimerStart.OnClientEvent:Connect(function(trackName, startTime, cpCount)
    if not _G.AutoTail or trackName ~= "Tail" then return end
    
    -- Tunggu Lampu Hijau
    while workspace:GetServerTimeNow() < startTime do 
        task.wait(0.01) 
    end
    
    -- LIVE TIMER LOOP (95s)
    for i = 1, 95 do
        if not _G.AutoTail then break end
        task.wait(1)
    end
    
    local car = workspace.AVehicleStorage:FindFirstChild(lp.Name)
    if not car then 
        return 
    end

    -- STEP 1: Streaming Bypass
    car:PivotTo(TAIL_FINISH) 
    task.wait(3)

    -- STEP 2: Checkpoint Run
    local raceFolder = workspace:FindFirstChild("Races")
    local tailFolder = raceFolder and raceFolder:FindFirstChild("Tail")
    local map = tailFolder and tailFolder:FindFirstChild("TailMap")
    
    if map then
        local cps = map:FindFirstChild("Checkpoints")
        if cps then
            for i = 1, 32 do
                if not _G.AutoTail then break end
                local cp = cps:FindFirstChild(tostring(i))
                if cp then
                    car:PivotTo(cp.CFrame + Vector3.new(0, 2, 0))
                    task.wait(0.4) 
                end
            end
            -- Finish beneran
            task.wait(0.5)
            car:PivotTo(TAIL_FINISH)
        end
    else

    end
end)

RaceRemotes.Race_Finish.OnClientEvent:Connect(function()
    if _G.AutoTail then
        for i = 9, 1, -1 do
            task.wait(1)
        end
        RaceRemotes.Race_Join:FireServer("Tail")
    end
end)






-- [[ Autodrag LOGIC ]] --
remotes:WaitForChild("Race_TimerStart").OnClientEvent:Connect(function(trackName, startTime, cpCount)
    if not _G.AutoFarm then return end
    
    
    -- 1. Tunggu GO!
    while workspace:GetServerTimeNow() < startTime do 
        task.wait(0.01) 
    end
    
    
    -- 2. Tunggu ExploitTime
    task.wait(15.0) 

    -- 3. CARI MAP & TELEPORT
    local car = getMyCar()
    local mapFolder = nil
    
    for i = 1, 15 do
        local raceFolder = workspace.Races:FindFirstChild(trackName)
        mapFolder = raceFolder and raceFolder:FindFirstChild(trackName .. "Map")
        if mapFolder then break end
        task.wait(0.5)
    end
    
    if car and mapFolder then
        local cpFolder = mapFolder:WaitForChild("Checkpoints", 5)
        
        if cpFolder then
            for i = 1, cpCount do
                pcall(function()
                    local targetCP = cpFolder:FindFirstChild(tostring(i))
                    if targetCP then
                        car:PivotTo(targetCP.CFrame + Vector3.new(0, 2, 0))
                        task.wait(0.3)
                    end
                end)
            end
        end
        
        -- FINAL FINISH
        car:PivotTo(FINISH_POS)
    end
end)

-- [[ FIX REJOIN DELAY 9s ]] --
remotes:WaitForChild("Race_Finish").OnClientEvent:Connect(function()
    if not _G.AutoFarm then return end
    
    StatusSection:SetTitle("Status: Waiting 9s for Reset...")
    task.wait(9) -- Sesuai request lu: Delay 9 detik biar server aman
    joinRace()
end)

