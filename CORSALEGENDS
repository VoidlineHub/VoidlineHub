-- [[ UTILS ]] --
local function formatNumber(v)
    local s = tostring(math.floor(v))
    return s:reverse():gsub("%d%d%d", "%1."):reverse():gsub("^%.", "")
end

local function sendWebhook(status)
    if not _G.WebhookEnabled or _G.WebhookURL == "" or not _G.WebhookURL:find("discord.com/api/webhooks") then return end
    
    local cash = lp.leaderstats:FindFirstChild("Cash") and lp.leaderstats.Cash.Value or 0
    local miles = lp.leaderstats:FindFirstChild("Miles") and lp.leaderstats.Miles.Value or 0
    
    local data = {
        ["embeds"] = {{
            ["title"] = "Voidline | Logs Monitor",
            ["color"] = 0x000000,
            ["fields"] = {
                {["name"] = "Current Race", ["value"] = _G.SelectedRace, ["inline"] = true},
                {["name"] = "Current Prize", ["value"] = "$" .. formatNumber(currentPrize), ["inline"] = true},
                {["name"] = "Total Cash", ["value"] = "$" .. formatNumber(cash), ["inline"] = true},
                {["name"] = "Total Miles", ["value"] = formatNumber(miles) .. " Miles", ["inline"] = true},
                {["name"] = "Status Update", ["value"] = "```" .. status .. "```", ["inline"] = false}
            },
            ["footer"] = {["text"] = "script pribadi"},
            ["timestamp"] = DateTime.now():ToIsoDate()
        }}
    }
    local requestFunc = syn and syn.request or http_request or request or (http and http.request)
    if requestFunc then requestFunc({Url = _G.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)}) end
end

