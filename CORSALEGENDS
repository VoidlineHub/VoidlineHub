-- [[ RACE LOGIC ]] --
local function joinRace()
    if not _G.AutoFarm then return end
    local mode = "AirportDrag"
    if _G.SelectedRace == "Tail of the Dragon" then mode = "Tail"
    elseif _G.SelectedRace == "Snetterton Circuit" then mode = "Snetterton"
    elseif _G.SelectedRace == "Highway Sprint" then mode = "HighwayAround"
    elseif _G.SelectedRace == "City Curve" then mode = "CityCurve"
    elseif _G.SelectedRace == "Lakeside Run" then mode = "Lakeside" end
    remotes.Races.Race_Join:FireServer(mode)
end

remotes.Races.Race_PrizeInfo.OnClientEvent:Connect(function(_, _, _, pool) currentPrize = pool or 0 end)

remotes.Races.Race_TimerStart.OnClientEvent:Connect(function(trackName, startTime)
    if not _G.AutoFarm then return end
    while workspace:GetServerTimeNow() < startTime do task.wait(0.01) end
    local car = workspace.AVehicleStorage:FindFirstChild(lp.Name)
    if not car then return end

    if trackName == "CityCurve" then
        for i = 1, 17 do task.wait(2) car:PivotTo(workspace.Races.CityCurve.CurveMap.Checkpoints[tostring(i)].CFrame + Vector3.new(0,2,0)) end
        task.wait(4) car:PivotTo(FINISH_CF["City Curve"])
    elseif trackName == "Lakeside" then
        for i = 1, 5 do task.wait(3) car:PivotTo(workspace.Races.Lakeside.LakesideMap.Checkpoints[tostring(i)].CFrame + Vector3.new(0,2,0)) end
        task.wait(3) car:PivotTo(FINISH_CF["Lakeside Run"])
    elseif trackName == "HighwayAround" then
        for i = 1, 18 do task.wait(7) car:PivotTo(workspace.Races.HighwayAround.HighwayAroundMap.Checkpoints[tostring(i)].CFrame + Vector3.new(0,2,0)) end
        task.wait(9) car:PivotTo(FINISH_CF["Highway Sprint"])
    elseif trackName == "Snetterton" then
        for i = 1, 3 do task.wait(15) car:PivotTo(workspace.Races.Snetterton.SnettertonMap.Checkpoints[tostring(i)].CFrame + Vector3.new(0,2,0)) end
        task.wait(16) car:PivotTo(FINISH_CF["Snetterton Circuit"])
    elseif trackName == "Tail" then
        task.wait(95) 
        car:PivotTo(FINISH_CF["Tail of the Dragon"]) 
        task.wait(3)
        
        -- FIXED LOGIC TAIL (Gua ganti pake loop yang lebih pasti sampe 32)
        local tailCheckpoints = workspace.Races.Tail.TailMap.Checkpoints
        for i = 1, 32 do 
            local cp = tailCheckpoints:FindFirstChild(tostring(i))
            if cp then
                car:PivotTo(cp.CFrame + Vector3.new(0, 2, 0))
                task.wait(0.4) 
            end
        end
        -- Extra wait biar server register CP terakhir
        task.wait(1)
        car:PivotTo(FINISH_CF["Tail of the Dragon"])
        
    elseif trackName == "AirportDrag" then
        task.wait(5) car:PivotTo(workspace.Races.AirportDrag.AirportDragMap.Checkpoints["1"].CFrame + Vector3.new(0,2,0))
        task.wait(5) car:PivotTo(workspace.Races.AirportDrag.AirportDragMap.Checkpoints["2"].CFrame + Vector3.new(0,2,0))
        task.wait(3) car:PivotTo(workspace.Races.AirportDrag.AirportDragMap.Checkpoints["3"].CFrame + Vector3.new(0,2,0))
        task.wait(4) car:PivotTo(FINISH_CF["Airport Drag"])
    end
    sendWebhook("Race Finished! Ready to next.")
end)

remotes.Races.Race_Finish.OnClientEvent:Connect(function()
    if not _G.AutoFarm then return end
    task.wait(10)
    joinRace()
end)

