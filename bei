local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "VoidlineHub | Official",
   LoadingTitle = "Bus Driving Indonesia",
   LoadingSubtitle = "by VoidLineHub",
   Theme = "AmberGlow"
})

local LP = game.Players.LocalPlayer
local Remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Ambil data bus dari Server (Sesuai logic GarageController kamu)
local CarData = Remotes.GetClientCustomizationData:InvokeServer()
local OwnedCarsFolder = LP:WaitForChild("PlayerData"):WaitForChild("OwnedCars")

_G.AutoFull = false
_G.SelectedBus = "" 
local busOptions = {}

-- SCANNING BUS YANG KAMU PUNYA
for _, car in pairs(OwnedCarsFolder:GetChildren()) do
    local carID = car.Name
    local carInfo = CarData.CarData_Cars[carID]
    if carInfo then
        table.insert(busOptions, carID) -- Masukin ID internal buat spawner
    end
end

-- Fallback kalau scan gagal
if #busOptions == 0 then table.insert(busOptions, "Jetbus_3_RM _SHD") end
_G.SelectedBus = busOptions[1]

local lastTarget = nil
local noBillboardTime = 0
local jobStarted = false
local CirebonEndCF = CFrame.new(-26471.1445, -212.441071, 33276.8203, -0.0246282816, 0, 0.999696672, 0, 1, 0, -0.999696672, 0, -0.0246282816)

-- --- UTILITY ---
local function GetMyBus()
    return workspace.SpawnedVehicles:FindFirstChild(_G.SelectedBus)
end

local function SetFreeze(state)
    local bus = GetMyBus()
    if bus then
        for _, part in pairs(bus:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = state
                if not state then
                    part.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end
            end
        end
    end
end

local function InstantTP(targetCF)
    local bus = GetMyBus()
    if not bus then return end
    SetFreeze(false) 
    task.wait(0.1)
    for i = 1, 3 do
        bus:PivotTo(targetCF)
        task.wait(0.05)
    end
end

local function GetActiveStop()
    for _, part in pairs(workspace.Checkpoints:GetChildren()) do
        local bs = part:FindFirstChild("BusStop")
        if bs and bs:IsA("BillboardGui") and bs.Enabled == true then
            return part
        end
    end
    return nil
end

-- --- UI ---
local MainTab = Window:CreateTab("Main Farm", "play")

MainTab:CreateSection("Garage Scanner")

local BusDropdown = MainTab:CreateDropdown({
   Name = "Select Owned Bus",
   Options = busOptions,
   CurrentOption = {busOptions[1]},
   MultipleOptions = false,
   Callback = function(Option)
      _G.SelectedBus = Option[1]
   end,
})

-- Tombol Refresh Dropdown (kalau baru beli bus)
MainTab:CreateButton({
   Name = "Refresh Garage List",
   Callback = function()
       local newOptions = {}
       for _, car in pairs(OwnedCarsFolder:GetChildren()) do
           table.insert(newOptions, car.Name)
       end
       BusDropdown:Set(newOptions)
   end,
})

MainTab:CreateSection("Automation")
local StatusLabel = MainTab:CreateLabel("Status: Waiting", "clock")

local function SetStatus(text)
    StatusLabel:Set("Status: " .. text)
end

MainTab:CreateToggle({
    Name = "Full Auto 3 MIN (Dynamic Bus)",
    CurrentValue = false,
    Callback = function(Value)
        _G.AutoFull = Value
        if not Value then 
            lastTarget = nil 
            jobStarted = false
            SetFreeze(false)
            SetStatus("Idle")
        end
        
        while _G.AutoFull do
            local hum = LP.Character and LP.Character:FindFirstChild("Humanoid")
            
            if not jobStarted then
                SetStatus("Spawning: " .. _G.SelectedBus)
                Remotes:WaitForChild("SpawnCar"):FireServer(_G.SelectedBus)
                task.wait(4)
                local bus = GetMyBus()
                
                if bus and bus:FindFirstChild("DriveSeat") then
                    bus.DriveSeat:Sit(hum)
                    task.wait(2)
                    
                    SetStatus("Firing Job...")
                    Remotes:WaitForChild("StartBusJob"):InvokeServer("Baranangsiang_ke_Cirebon1")
                    task.wait(1)
                    
                    hum.Jump = true
                    task.wait(1.5)
                    
                    SetStatus("Final Refresh...")
                    Remotes:WaitForChild("SpawnCar"):FireServer(_G.SelectedBus)
                    task.wait(4)
                    bus = GetMyBus() 
                    
                    if bus and bus:FindFirstChild("DriveSeat") then
                        bus.DriveSeat:Sit(hum)
                        jobStarted = true
                    end
                end
            end
            
            local target = GetActiveStop()
            if target then
                noBillboardTime = 0 
                if target ~= lastTarget then
                    InstantTP(target.CFrame)
                    lastTarget = target
                    task.wait(2)
                    SetFreeze(true) 
                    
                    for i = 60, 1, -1 do
                        if not _G.AutoFull then break end
                        SetStatus("STATIONARY: " .. i .. "s")
                        task.wait(1)
                    end
                    SetFreeze(false)
                    
                    for i = 120, 1, -1 do
                        if not _G.AutoFull then break end
                        SetStatus("ON ROUTE: " .. i .. "s")
                        task.wait(1)
                    end
                end
            else
                if jobStarted then
                    noBillboardTime = noBillboardTime + 1
                    SetStatus("Finalizing: " .. (60 - noBillboardTime) .. "s")
                    
                    if noBillboardTime >= 60 then
                        SetStatus("TP to End Position")
                        InstantTP(CirebonEndCF)
                        task.wait(2)
                        SetFreeze(true)
                        
                        for i = 180, 1, -1 do
                            if not _G.AutoFull then break end
                            SetStatus("WAITING PAYOUT: " .. i .. "s")
                            task.wait(1)
                        end
                        
                        SetFreeze(false)
                        jobStarted = false
                        lastTarget = nil
                        noBillboardTime = 0
                        local bus = GetMyBus()
                        if bus then bus:Destroy() end 
                        task.wait(5)
                    end
                end
            end
            task.wait(1)
        end
    end
})
