MainTab:Button({
    Title = "Force Rescan",
    Desc = "Pindai ulang garasi secara manual",
    Callback = function()
        MotorDropdown:SetValues(getGarageData())
    end
})

-- [[ 5. BACKGROUND AUTO REFRESH ]] --
task.spawn(function()
    while true do
        local data = getGarageData()
        if #data ~= #_G.MotorOptions then
            _G.MotorOptions = data
            MotorDropdown:SetValues(data)
        end
        task.wait(10)
    end
end)
