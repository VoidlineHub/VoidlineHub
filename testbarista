local CF = {
    Supply = CFrame.new(-5116.78418, 5.78931046, -670.858887),
    Machine = CFrame.new(-4997.1665, 1.58353043, -795.047607),
    Register = CFrame.new(-4994.06934, 1.30402756, -760.247437),
    Start = CFrame.new(-4989.80078, 5.30382967, -715.013062)
}

local Prompts = {
    Machine = workspace.BaristaJob.Interactions.MachinePart.MachinePart.MachinePrompt,
    Register = workspace.BaristaJob.Interactions.RegisterPart.RegisterPart.RegisterPrompt,
    Supply = workspace.BaristaJob.Interactions.SupplyPart.SupplyPart.SupplyPrompt,
    Job = workspace.BaristaJob.Interactions.StartPart.StartPart.JobPrompt
}

-- [[ GLOBAL VARIABLES ]]
_G.AutoFarmBarista = false
local LastActivity = tick()
local StartSessionTime = tick()
local IsResting = false

-- [[ UTILITY FUNCTIONS ]]

local function GetBaristaElements()
    local Gui = LP.PlayerGui:FindFirstChild("BaristaGUI")
    if Gui then
        local OrderText = Gui:FindFirstChild("StatusFrame") and Gui.StatusFrame:FindFirstChild("OrderText")
        local Minigame = Gui:FindFirstChild("MinigameFrame")
        return Gui, OrderText, Minigame
    end
    return nil, nil, nil
end

local function BypassTP(targetCF, forceSitBefore)
    local Char = LP.Character or LP.CharacterAdded:Wait()
    local Hum = Char:WaitForChild("Humanoid")
    local Root = Char:WaitForChild("HumanoidRootPart")
    
    if Hum and Root then
        if forceSitBefore then
            Hum.Sit = true
            task.wait(0.8) -- Jeda biar server register status duduk
        else
            Hum.Sit = true
            task.wait(0.5)
        end
        Root.CFrame = targetCF
        task.wait(0.3)
        Hum.Sit = false
    end
end

-- // FUNGSI ISTIRAHAT (SETIAP 2 JAM)
local function RestSystem()
    IsResting = true
    warn("[VOIDLINE] Safety limit reached! Resting...")
    
    -- 1. Reset Character
    if LP.Character then
        LP.Character:BreakJoints()
    end
    task.wait(5) -- Tunggu respawn
    
    -- 2. Ganti ke Civilian
    local args = {"Civilian", 0, 0, 0, "Detector"}
    ReplicatedStorage:WaitForChild("JobEvents"):WaitForChild("TeamChangeRequest"):FireServer(unpack(args))
    
    warn("[VOIDLINE] Resting as Civilian for 30 seconds...")
    task.wait(60) -- Durasi istirahat biar aman
    
    StartSessionTime = tick() -- Reset timer sesi
    IsResting = false
    warn("[VOIDLINE] Rest finished. Back to work!")
end

local function ExecuteStartSequence()
    if IsResting then return end
    
    local tr = ReplicatedStorage:FindFirstChild("TeamChangeRequest", true)
    if LP.Team and LP.Team.Name ~= "Barista" and tr then
        tr:FireServer("Barista", 11378976, 0, 0, "Detector")
        task.wait(2.5)
    end
    
    -- KHUSUS START: Duduk dulu baru TP (Sesuai request lu)
    BypassTP(CF.Start, true)
    task.wait(0.8)
    
    if Prompts.Job and Prompts.Job.Enabled then
        fireproximityprompt(Prompts.Job)
    end
    LastActivity = tick()
end

-- [[ MAIN LOOP ]]
task.spawn(function()
    while task.wait(0.6) do
        if _G.AutoFarmBarista and not IsResting then
            -- Cek durasi sesi (7200 detik = 2 jam)
            if (tick() - StartSessionTime) >= 7200 then
                RestSystem()
                ExecuteStartSequence()
                continue
            end

            local _, OrderTextLabel, MinigameFrame = GetBaristaElements()
            
            -- Stuck 4 menit auto reset
            if tick() - LastActivity >= 240 then
                ExecuteStartSequence()
            end

            if OrderTextLabel then
                local txt = OrderTextLabel.Text:lower()
                local isBroken = (OrderTextLabel.TextColor3.R > 0.8 and (txt:find("break") or txt:find("down")))
                
                if isBroken then
                    BypassTP(CF.Supply, false)
                    task.wait(0.5)
                    fireproximityprompt(Prompts.Supply)
                    LastActivity = tick()
                    task.wait(0.5)
                    BypassTP(CF.Machine, false)
                    fireproximityprompt(Prompts.Machine)
                elseif Prompts.Machine.Enabled and not (MinigameFrame and MinigameFrame.Visible) then
                    BypassTP(CF.Machine, false)
                    fireproximityprompt(Prompts.Machine)
                    LastActivity = tick()
                    repeat task.wait(0.5)
                        LastActivity = tick()
                    until not (MinigameFrame and MinigameFrame.Visible) or not _G.AutoFarmBarista or IsResting
                elseif Prompts.Register.Enabled and not (MinigameFrame and MinigameFrame.Visible) then
                    task.wait(0.5)
                    BypassTP(CF.Register, false)
                    task.wait(0.5)
                    fireproximityprompt(Prompts.Register)
                    LastActivity = tick()
                end
            end
        end
    end
end)

-- TargetZone Exploit
RunService.Heartbeat:Connect(function()
    local _, _, MinigameFrame = GetBaristaElements()
    if _G.AutoFarmBarista and MinigameFrame and MinigameFrame.Visible then
        local tz = MinigameFrame:FindFirstChild("TargetZone", true)
        if tz then tz.Size = UDim2.new(1, 0, 1, 0); tz.Position = UDim2.new(0, 0, 0, 0) end
    end
end)

