local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Driving empire",
   LoadingTitle = "Fixing Queue System...",
   LoadingSubtitle = "by Voidline x Specter",
   ConfigurationSaving = { Enabled = true, FileName = "VoidlineDE_Fix" }
})

-- [[ SERVICES ]]
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LP = game.Players.LocalPlayer
local Remotes = require(ReplicatedStorage.Modules.Shared.Remotes)
local CriminalConstants = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalConstants)

_G.AutoFarm = false
_G.FarmDelay = 5.0 -- Jeda antar ATM (Kasih 2 detik biar aman)

-- [[ FUNCTION FIXED ]]
local function GetAvailableATM()
    local Spawners = workspace.Game.Jobs.CriminalATMSpawners:GetChildren()
    for _, spawner in ipairs(Spawners) do
        local CriminalATM = spawner:FindFirstChild("CriminalATM")
        if CriminalATM and CriminalATM:GetAttribute("State") ~= "Busted" then
            local ATM = CriminalATM:FindFirstChild("ATM")
            if ATM then return ATM end
        end
    end
    return nil
end

local function ProcessRob(TargetATM)
    local CriminalATMFolder = TargetATM.Parent
    
    -- 1. TP ke ATM
    LP.Character:PivotTo(TargetATM.CFrame * CFrame.new(0, 0, 3))
    task.wait(0.5) -- Jeda wajib biar server tau kita udah nyampe
    
    -- 2. Tembak Start
    Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustStart, CriminalATMFolder)
    
    -- 3. JEDA PROSES (PENTING!)
    -- Jangan langsung Complete, kasih jeda biar server gak curiga
    task.wait(0.5) 
    
    -- 4. Tembak Complete
    local success, res = Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustComplete, CriminalATMFolder)
    
    if success then
        Rayfield:Notify({Title = "Voidline", Content = "ATM Berhasil!"})
    else
        warn("Gagal Rob: " .. tostring(res))
    end
end

-- [[ UI MAIN ]]
local MainTab = Window:CreateTab("Auto Farm", 4483362458)

MainTab:CreateToggle({
   Name = "Fast Auto Rob (Bypass Prompt)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoFarm = Value
      
      task.spawn(function()
          while _G.AutoFarm do
              local Target = GetAvailableATM()
              
              if Target then
                  -- Force Dismount
                  local Hum = LP.Character:FindFirstChildOfClass("Humanoid")
                  if Hum and Hum.SeatPart then Hum.Sit = false task.wait(0.2) end
                  
                  -- Eksekusi Rob
                  ProcessRob(Target)
                  
                  -- Jeda antar ATM biar gak kena kick/error nil
                  task.wait(_G.FarmDelay)
              else
                  task.wait(1)
              end
          end
      end)
   end,
})

MainTab:CreateSlider({
   Name = "Wait Delay (Saran: 2s)",
   Min = 1,
   Max = 5,
   CurrentValue = 2,
   ValueName = "Detik",
   Callback = function(Value) _G.FarmDelay = Value end,
})
