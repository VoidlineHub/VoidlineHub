local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "VoidlineHub | Full Auto",
   LoadingTitle = "Bus Job 110M Automation",
   LoadingSubtitle = "by habilyusuf101",
   Theme = "AmberGlow"
})

local LP = game.Players.LocalPlayer
_G.AutoFull = false
local lastTarget = nil

-- Koordinat Finish Cirebon (End Job)
local CirebonEndCF = CFrame.new(-26471.1445, -212.441071, 33276.8203, -0.0246282816, 0, 0.999696672, 0, 1, 0, -0.999696672, 0, -0.0246282816)

-- Fungsi Ambil Bus
local function GetMyBus()
    return workspace.SpawnedVehicles:FindFirstChild("Jetbus_3_RM _SHD")
end

-- FUNGSI FORCE CLICK (Klik tombol UI secara paksa)
local function ForceClick(button)
    if button and button:IsA("GuiButton") then
        local events = {"MouseButton1Click", "MouseButton1Down", "Activated"}
        for _, eventName in pairs(events) do
            local conns = getconnections(button[eventName])
            for _, connection in pairs(conns) do
                connection:Fire()
            end
        end
    end
end

-- 1. FUNGSI SPAWN & SETUP (Logic Index 3 Gabungan)
local function SetupBus()
    local bus = GetMyBus()
    
    -- Spawn Bus jika tidak ada
    if not bus then
        game:GetService("ReplicatedStorage").Remotes.SpawnCar:FireServer("Jetbus_3_RM _SHD")
        task.wait(3)
        bus = GetMyBus()
    end
    
    if bus and bus:FindFirstChild("DriveSeat") then
        -- Force Seat
        if LP.Character.Humanoid.SeatPart ~= bus.DriveSeat then
            bus.DriveSeat:Sit(LP.Character.Humanoid)
            task.wait(1)
        end
        
        -- Logic Pilih Rute Index 3 (Rp 110,000,000)
        local gui = LP.PlayerGui:FindFirstChild("BusJobGUI")
        if gui and gui.MainFrame.Visible == true then
            local targetButton = gui.MainFrame.RouteSelectionFrame.RouteList:GetChildren()[3]
            if targetButton then
                ForceClick(targetButton)
                Rayfield:Notify({Title = "Route", Content = "Rute 110M Cirebon Terpilih!"})
                task.wait(1)
            end
        end
    end
end

-- 2. FUNGSI TELEPORT STABIL
local function InstantTP(targetCF)
    local bus = GetMyBus()
    if not bus then return end

    -- Unanchor biar bisa pindah
    if bus.PrimaryPart and bus.PrimaryPart.Anchored then
        for _, p in pairs(bus:GetDescendants()) do
            if p:IsA("BasePart") then p.Anchored = false end
        end
    end

    -- Reset gaya gerak
    for _, part in pairs(bus:GetDescendants()) do
        if part:IsA("BasePart") then
            part.AssemblyLinearVelocity = Vector3.new(0,0,0)
            part.AssemblyAngularVelocity = Vector3.new(0,0,0)
        end
    end

    bus:PivotTo(targetCF)
    
    task.wait(0.1)
    for _, part in pairs(bus:GetDescendants()) do
        if part:IsA("BasePart") then
            part.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end
    end
end

-- 3. SCAN BILLBOARD
local function GetActiveStop()
    for _, part in pairs(workspace.Checkpoints:GetChildren()) do
        local bs = part:FindFirstChild("BusStop")
        if bs and bs:IsA("BillboardGui") and bs.Enabled == true then
            return part
        end
    end
    return nil
end

-- --- UI TABS ---
local MainTab = Window:CreateTab("Automation", "play")

MainTab:CreateToggle({
    Name = "Full Auto Loop (Cirebon 110M)",
    CurrentValue = false,
    Callback = function(Value)
        _G.AutoFull = Value
        if not Value then lastTarget = nil end
        
        while _G.AutoFull do
            local bus = GetMyBus()
            
            -- Setup & Pilih Rute Otomatis
            if not bus or (LP.Character.Humanoid.SeatPart == nil) then
                SetupBus()
            end
            
            -- Scan Checkpoint
            local target = GetActiveStop()
            if target and target ~= lastTarget then
                InstantTP(target.CFrame)
                lastTarget = target
                Rayfield:Notify({Title = "Checkpoint", Content = "TP Berhasil! Delay 25 Detik."})
                task.wait(25) -- Update Delay 25 detik
            end
            
            if not target then
                lastTarget = nil
            end
            
            -- Cek End Job (Harjamukti Cirebon)
            local gui = LP.PlayerGui:FindFirstChild("BusJobGUI")
            if gui and gui:FindFirstChild("JobStatusFrame") and gui.JobStatusFrame.Visible then
                local label = gui.JobStatusFrame.InfoLabel.Text
                if label:find("Cirebon") or label:find("Harjamukti") or label:find("Selesai") then
                    InstantTP(CirebonEndCF)
                    Rayfield:Notify({Title = "Finish", Content = "Sampai di Harjamukti! Gaji 110M Masuk."})
                    task.wait(10)
                end
            end
            
            task.wait(1)
        end
    end
})

MainTab:CreateButton({
    Name = "Teleport Cirebon Manual",
    Callback = function()
        InstantTP(CirebonEndCF)
    end
})

Rayfield:Notify({Title = "Voidline Loaded", Content = "Sistem 110M Cirebon (Delay 25s) Ready!"})
