local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "VoidlineHub | Full Auto V10",
   LoadingTitle = "Cirebon 110M Extreme Method",
   LoadingSubtitle = "by habilyusuf101",
   Theme = "AmberGlow"
})

local LP = game.Players.LocalPlayer
local Remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
_G.AutoFull = false
local lastTarget = nil
local noBillboardTime = 0
local jobStarted = false

-- Koordinat Finish Cirebon (End Job)
local CirebonEndCF = CFrame.new(-26471.1445, -212.441071, 33276.8203, -0.0246282816, 0, 0.999696672, 0, 1, 0, -0.999696672, 0, -0.0246282816)

-- Fungsi Ambil Bus
local function GetMyBus()
    return workspace.SpawnedVehicles:FindFirstChild("Jetbus_3_RM _SHD")
end

-- FUNGSI FREEZE
local function SetFreeze(state)
    local bus = GetMyBus()
    if bus then
        for _, part in pairs(bus:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = state
                if not state then
                    part.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end
            end
        end
    end
end

-- FUNGSI TELEPORT FORCE
local function InstantTP(targetCF)
    local bus = GetMyBus()
    if not bus then return end

    SetFreeze(false) 
    task.wait(0.1)
    
    -- Force TP 3x biar nempel
    for i = 1, 3 do
        bus:PivotTo(targetCF)
        task.wait(0.05)
    end
    
    for _, part in pairs(bus:GetDescendants()) do
        if part:IsA("BasePart") then
            part.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end
    end
end

-- SCAN BILLBOARD
local function GetActiveStop()
    for _, part in pairs(workspace.Checkpoints:GetChildren()) do
        local bs = part:FindFirstChild("BusStop")
        if bs and bs:IsA("BillboardGui") and bs.Enabled == true then
            return part
        end
    end
    return nil
end

-- --- UI TABS ---
local MainTab = Window:CreateTab("Automation", "play")

MainTab:CreateToggle({
    Name = "God Mode (Double Spawn Method)",
    CurrentValue = false,
    Callback = function(Value)
        _G.AutoFull = Value
        if not Value then 
            lastTarget = nil 
            jobStarted = false
            SetFreeze(false)
        end
        
        while _G.AutoFull do
            local bus = GetMyBus()
            local hum = LP.Character and LP.Character:FindFirstChild("Humanoid")
            
            -- STEP 1: SETUP (SPAWN 1 -> DUDUK -> FIRE -> LOMPAT -> SPAWN 2 -> DUDUK)
            if not jobStarted then
                -- 1. Spawn Bus Pertama
                Remotes:WaitForChild("SpawnCar"):FireServer("Jetbus_3_RM _SHD")
                task.wait(3)
                bus = GetMyBus()
                
                if bus and bus:FindFirstChild("DriveSeat") then
                    -- 2. Duduk
                    bus.DriveSeat:Sit(hum)
                    task.wait(1.5)
                    
                    -- 3. Fire Remote Job
                    local args = {"Baranangsiang_ke_Cirebon1"}
                    Remotes:WaitForChild("StartBusJob"):InvokeServer(unpack(args))
                    task.wait(1)
                    
                    -- 4. Lompat (Reset Ownership)
                    hum.Jump = true
                    task.wait(1)
                    
                    -- 5. Spawn Bus Kedua (Refresh)
                    Remotes:WaitForChild("SpawnCar"):FireServer("Jetbus_3_RM _SHD")
                    task.wait(3)
                    bus = GetMyBus() -- Update variabel bus ke yang baru
                    
                    -- 6. Duduk Lagi di Bus Baru
                    if bus and bus:FindFirstChild("DriveSeat") then
                        bus.DriveSeat:Sit(hum)
                        jobStarted = true
                        Rayfield:Notify({Title = "Success", Content = "Double Spawn Done! Job Synchronized."})
                    end
                end
            end
            
            -- STEP 2: CHECKPOINT HANDLING (15s FREEZE + 20s DELAY)
            local target = GetActiveStop()
            
            if target then
                noBillboardTime = 0 
                
                if target ~= lastTarget then
                    InstantTP(target.CFrame)
                    lastTarget = target
                    
                    task.wait(2)
                    SetFreeze(true) -- Freeze 15s sesuai request terakhir
                    
                    Rayfield:Notify({Title = "Status", Content = "Locked 15s at Checkpoint..."})
                    task.wait(15)
                    
                    SetFreeze(false)
                    Rayfield:Notify({Title = "Status", Content = "Cooldown 20s before next TP..."})
                    task.wait(20)
                end
            else
                -- STEP 3: END JOB LOGIC (AKHIR RUTE)
                if jobStarted then
                    noBillboardTime = noBillboardTime + 1
                    
                    -- Tunggu 1 menit tanpa billboard (tanda finish 8 titik)
                    if noBillboardTime >= 60 then
                        Rayfield:Notify({Title = "Finish", Content = "TP to Cirebon End Position!"})
                        InstantTP(CirebonEndCF)
                        task.wait(15) -- Delay payout
                        
                        -- Loop Reset
                        jobStarted = false
                        lastTarget = nil
                        noBillboardTime = 0
                        if bus then bus:Destroy() end 
                    end
                end
            end
            
            task.wait(1)
        end
    end
})

Rayfield:Notify({Title = "Voidline Loaded", Content = "Method V10 (Double-Spawn) Aktif!"})
