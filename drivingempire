-- [[ ADEN SCRIPTS v10.2 - REBUILT BY VOIDLINE ]]
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local LP = game.Players.LocalPlayer
local ReplicatedStorage = game:GetService('ReplicatedStorage')
local VirtualUser = game:GetService('VirtualUser')

-- Modules Original CDID
local Remotes = require(ReplicatedStorage.Modules.Shared.Remotes)
local CriminalConstants = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalConstants)
local CriminalUtil = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalUtil)
local ATMJobTask = require(ReplicatedStorage.Modules.Client.Jobs.Tasks.CriminalATMJobTask)

-- Global Config (Connecting UI to Logic)
_G.AutoFarm = false
_G.BagLimit = 200
_G.Delays = {
    Task1 = 1,    -- Teleport Delay
    Task2 = 2,    -- Sale Processing
    Task3 = 0.15, -- Start Load
    Task4 = 5,    -- Robbery Cooldown (Bust Delay)
    Task7 = 0.8   -- Platform Loading
}

local DROP_POINT_CFRAME = CFrame.new(-2543.30786, 11.8932114, 4030.31909)
local BlacklistATM = {}

-- [[ FUNCTION HELPERS ]]
local function GetMoneyBagCount()
    local count = 0
    local items = LP.Backpack:GetChildren()
    for _, tool in pairs(LP.Character:GetChildren()) do
        if tool:IsA("Tool") then table.insert(items, tool) end
    end
    for _, item in pairs(items) do
        if item.Name:match("MoneyBag") or item:GetAttribute("MoneyAmount") then
            count = count + (item:GetAttribute("MoneyAmount") or 1)
        end
    end
    return count
end

local function GetTargetATM()
    local Spawners = workspace.Game.Jobs.CriminalATMSpawners:GetChildren()
    for _, spawner in pairs(Spawners) do
        local ATM = spawner:FindFirstChild("ATM", true) 
        if ATM and not BlacklistATM[ATM] then
            local Folder = ATM.Parent
            if Folder:GetAttribute("State") ~= CriminalConstants.ATMStates.Busted then
                local engaging = Folder:GetAttribute("EngagingPlayerId")
                if not engaging or engaging == 0 or engaging == LP.UserId then
                    return ATM 
                end
            end
        end
    end
    return nil
end

-- [[ MAIN WINDOW ]]
local Window = Rayfield:CreateWindow({
    Name = "ADEN SCRIPTS v10.2",
    LoadingTitle = "ADEN SCRIPTS",
    LoadingSubtitle = "Premium Driving Empire Script",
    ConfigurationSaving = { Enabled = true, FolderName = "ADEN_SCRIPTS_CONFIG" }
})

local PlayerTab = Window:CreateTab("Player", "user")
local FarmTab = Window:CreateTab("Farming", "tractor")
local StatsTab = Window:CreateTab("Statistics", "bar-chart-2")

-- [[ PLAYER TAB ]]
PlayerTab:CreateSection("General")
PlayerTab:CreateToggle({
    Name = "Anti-AFK",
    CurrentValue = false,
    Callback = function(Value)
        if Value then
            LP.Idled:Connect(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new(), workspace.CurrentCamera.CFrame)
            end)
            Rayfield:Notify({Title = "Player Settings", Content = "Anti-AFK activated!"})
        end
    end
})

-- [[ FARMING TAB ]]
FarmTab:CreateSection("ATM Farm Control")
FarmTab:CreateToggle({
    Name = "Start ATM Farm",
    CurrentValue = false,
    Flag = "ATMFarmToggle",
    Callback = function(Value)
        _G.AutoFarm = Value
        task.spawn(function()
            while _G.AutoFarm do
                -- 1. Check Bag
                local currentBag = GetMoneyBagCount()
                if currentBag >= _G.BagLimit then
                    LP.Character:PivotTo(DROP_POINT_CFRAME * CFrame.new(0, 5, 0))
                    task.wait(0.5)
                    LP.Character:PivotTo(DROP_POINT_CFRAME)
                    task.wait(_G.Delays.Task2) -- Sale Processing Delay
                    pcall(function()
                        local DropObj = workspace.Game.Jobs:FindFirstChild("CriminalDropOffPoint") or workspace.Game.Jobs:FindFirstChild("CriminalDropOffPoints")
                        ATMJobTask.AttemptCompleteJob(DropObj)
                    end)
                    task.wait(1)
                end

                -- 2. Find and Rob
                local Target = GetTargetATM()
                if Target then
                    local Folder = Target.Parent
                    LP.Character:PivotTo(Target.CFrame * CFrame.new(0, 2, 4))
                    task.wait(_G.Delays.Task1) -- Teleport Delay

                    local sStart = Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustStart, Folder)
                    if sStart then
                        local waitTime = CriminalUtil.GetATMBustTime(LP) or 5.2
                        task.wait(waitTime + 0.5)
                        Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustComplete, Folder)
                        task.wait(_G.Delays.Task4) -- Robbery Cooldown (Bust Delay 5s)
                    else
                        BlacklistATM[Target] = true
                    end
                else
                    -- Patrol if no ATM (StreamingEnabled fix)
                    local Spawners = workspace.Game.Jobs.CriminalATMSpawners:GetChildren()
                    for i=1, #Spawners, 4 do
                        if not _G.AutoFarm or GetTargetATM() then break end
                        LP.Character:PivotTo(Spawners[i].CFrame * CFrame.new(0, 50, 0))
                        task.wait(_G.Delays.Task7) -- Platform Loading Delay
                    end
                end
                task.wait(0.1)
            end
        end)
    end
})

FarmTab:CreateSlider({
    Name = "Bag Limit",
    Range = {6, 200},
    Increment = 1,
    CurrentValue = 200,
    Flag = "BagSlider",
    Callback = function(Value) _G.BagLimit = Value end
})

FarmTab:CreateSection("⚙️ FARM SPEED CONFIGURATION (DELAYS)")

FarmTab:CreateInput({
    Name = "Task 1: Teleport Delay",
    PlaceholderText = "Default: 1",
    Callback = function(Text) _G.Delays.Task1 = tonumber(Text) or 1 end
})

FarmTab:CreateInput({
    Name = "Task 2: Sale Processing",
    PlaceholderText = "Default: 2",
    Callback = function(Text) _G.Delays.Task2 = tonumber(Text) or 2 end
})

FarmTab:CreateInput({
    Name = "Task 4: Robbery Cooldown (Bust)",
    PlaceholderText = "Default: 5",
    Callback = function(Text) _G.Delays.Task4 = tonumber(Text) or 5 end
})

FarmTab:CreateInput({
    Name = "Task 7: Platform Loading",
    PlaceholderText = "Default: 0.8",
    Callback = function(Text) _G.Delays.Task7 = tonumber(Text) or 0.8 end
})

-- [[ STATISTICS TAB ]]
StatsTab:CreateSection("Live Player Data")
local BagLabel = StatsTab:CreateLabel("Bag Progress: 0 / 200")

task.spawn(function()
    while true do
        if BagLabel then
            BagLabel:Set("Bag Progress: " .. GetMoneyBagCount() .. " / " .. _G.BagLimit)
        end
        task.wait(1)
    end
end)

Rayfield:Notify({Title = "ADEN v10.2", Content = "Script Loaded Successfully!"})
