local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "VoidlineHub | Full Auto V11",
   LoadingTitle = "Cirebon 110M Anti-Detect",
   LoadingSubtitle = "by habilyusuf101",
   Theme = "AmberGlow"
})

local LP = game.Players.LocalPlayer
local Remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
_G.AutoFull = false
local lastTarget = nil
local noBillboardTime = 0
local jobStarted = false

-- Koordinat Finish Cirebon (End Job)
local CirebonEndCF = CFrame.new(-26471.1445, -212.441071, 33276.8203, -0.0246282816, 0, 0.999696672, 0, 1, 0, -0.999696672, 0, -0.0246282816)

-- Fungsi Ambil Bus
local function GetMyBus()
    return workspace.SpawnedVehicles:FindFirstChild("Jetbus_3_RM _SHD")
end

-- FUNGSI FREEZE
local function SetFreeze(state)
    local bus = GetMyBus()
    if bus then
        for _, part in pairs(bus:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = state
                if not state then
                    part.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end
            end
        end
    end
end

-- FUNGSI TELEPORT FORCE
local function InstantTP(targetCF)
    local bus = GetMyBus()
    if not bus then return end

    SetFreeze(false) 
    task.wait(0.1)
    
    for i = 1, 3 do
        bus:PivotTo(targetCF)
        task.wait(0.05)
    end
    
    for _, part in pairs(bus:GetDescendants()) do
        if part:IsA("BasePart") then
            part.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end
    end
end

-- SCAN BILLBOARD
local function GetActiveStop()
    for _, part in pairs(workspace.Checkpoints:GetChildren()) do
        local bs = part:FindFirstChild("BusStop")
        if bs and bs:IsA("BillboardGui") and bs.Enabled == true then
            return part
        end
    end
    return nil
end

-- --- UI TABS ---
local MainTab = Window:CreateTab("Automation", "play")

MainTab:CreateToggle({
    Name = "Extreme Auto (Delay 58s)",
    CurrentValue = false,
    Callback = function(Value)
        _G.AutoFull = Value
        if not Value then 
            lastTarget = nil 
            jobStarted = false
            SetFreeze(false)
        end
        
        while _G.AutoFull do
            local bus = GetMyBus()
            local hum = LP.Character and LP.Character:FindFirstChild("Humanoid")
            
            -- STEP 1: SETUP (DOUBLE SPAWN METHOD)
            if not jobStarted then
                Remotes:WaitForChild("SpawnCar"):FireServer("Jetbus_3_RM _SHD")
                task.wait(3)
                bus = GetMyBus()
                
                if bus and bus:FindFirstChild("DriveSeat") then
                    bus.DriveSeat:Sit(hum)
                    task.wait(1.5)
                    
                    local args = {"Baranangsiang_ke_Cirebon1"}
                    Remotes:WaitForChild("StartBusJob"):InvokeServer(unpack(args))
                    task.wait(1)
                    
                    hum.Jump = true
                    task.wait(1)
                    
                    Remotes:WaitForChild("SpawnCar"):FireServer("Jetbus_3_RM _SHD")
                    task.wait(3)
                    bus = GetMyBus() 
                    
                    if bus and bus:FindFirstChild("DriveSeat") then
                        bus.DriveSeat:Sit(hum)
                        jobStarted = true
                        Rayfield:Notify({Title = "Success", Content = "Method V11 Active!"})
                    end
                end
            end
            
            -- STEP 2: CHECKPOINT HANDLING (DELAY 58s)
            local target = GetActiveStop()
            
            if target then
                noBillboardTime = 0 
                
                if target ~= lastTarget then
                    InstantTP(target.CFrame)
                    lastTarget = target
                    
                    task.wait(2)
                    SetFreeze(true) 
                    
                    Rayfield:Notify({Title = "Status", Content = "Freeze 28s at Checkpoint..."})
                    task.wait(28) -- Split Delay 1
                    
                    SetFreeze(false)
                    Rayfield:Notify({Title = "Status", Content = "Cooldown 30s before next TP..."})
                    task.wait(40) -- Split Delay 2 (Total 58s)
                end
            else
                -- STEP 3: LOGIC END POS (DAPET UANG)
                if jobStarted then
                    noBillboardTime = noBillboardTime + 1
                    
                    -- Jika billboard hilang selama 40 detik (berarti checkpoint 8 sudah lewat)
                    if noBillboardTime >= 40 then
                        Rayfield:Notify({Title = "Finish", Content = "TP to End Position for Payout!"})
                        
                        -- TELEPORT KE END POS
                        InstantTP(CirebonEndCF)
                        
                        -- Delay di End Pos biar uang masuk aman
                        task.wait(2)
                        SetFreeze(true)
                        Rayfield:Notify({Title = "Payout", Content = "Waiting 58s for Money..."})
                        task.wait(58) 
                        SetFreeze(false)
                        
                        -- Reset buat Loop Baru
                        jobStarted = false
                        lastTarget = nil
                        noBillboardTime = 0
                        if bus then bus:Destroy() end 
                        task.wait(5)
                    end
                end
            end
            
            task.wait(1)
        end
    end
})

Rayfield:Notify({Title = "Voidline Loaded", Content = "V11 (Double Spawn + 58s Delay) Ready!"})
