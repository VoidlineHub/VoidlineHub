local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Voidline",
   Title = "v1",
   LoadingTitle = "Method: 2s Teleport | 3s Rob",
   LoadingSubtitle = "by Voidline",
   ConfigurationSaving = { Enabled = true, FileName = "VoidlineDE_PureTP" }
})

-- [[ SERVICES ]]
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LP = game.Players.LocalPlayer
local Remotes = require(ReplicatedStorage.Modules.Shared.Remotes)
local CriminalConstants = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalConstants)

_G.AutoFarm = false

-- [[ SCANNER ]]
local function GetAvailableATM()
    local SpawnerPath = workspace:WaitForChild("Game"):WaitForChild("Jobs"):WaitForChild("CriminalATMSpawners")
    for _, spawner in ipairs(SpawnerPath:GetChildren()) do
        local CriminalATM = spawner:FindFirstChild("CriminalATM")
        -- Jika CriminalATM ada, berarti ATM Spawn (Ada Billboard & Highlight)
        if CriminalATM and CriminalATM:GetAttribute("State") ~= "Busted" then
            local ATM = CriminalATM:FindFirstChild("ATM")
            if ATM then return ATM end
        end
    end
    return nil
end

-- [[ THE GOLDEN METHOD: PURE TELEPORT ]]
local function ProcessRob(TargetATM)
    local CriminalATMFolder = TargetATM.Parent
    
    -- 1. PURE TELEPORT (INSTAN)
    LP.Character:PivotTo(TargetATM.CFrame * CFrame.new(0, 0, 3))
    
    -- 2. DELAY TELEPORT (METHOD LU: 2 DETIK)
    -- Kita diem di tempat selama 2 detik biar Server gak curiga Travel Speed
    task.wait(2) 
    
    -- 3. START FUNCTION
    Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustStart, CriminalATMFolder)
    
    -- 4. DELAY FUNCTION (METHOD LU: 3 DETIK)
    -- Waktu nunggu seolah-olah lagi nahan ProximityPrompt
    task.wait(3) 
    
    -- 5. COMPLETE FUNCTION
    local success, res = Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustComplete, CriminalATMFolder)
    
    if success then
        Rayfield:Notify({Title = "Voidline", Content = "ATM Berhasil (Pure TP Method)"})
    else
        warn("Gagal: " .. tostring(res))
    end
end

-- [[ UI TAB ]]
local MainTab = Window:CreateTab("Auto Farm", 4483362458)

MainTab:CreateToggle({
   Name = "Pure TP Auto Rob (2-3 Method)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoFarm = Value
      
      task.spawn(function()
          while _G.AutoFarm do
              local Target = GetAvailableATM()
              
              if Target then
                  -- Force Dismount (Wajib biar aksi gak invalid)
                  local Hum = LP.Character:FindFirstChildOfClass("Humanoid")
                  if Hum and Hum.SeatPart then Hum.Sit = false task.wait(0.1) end
                  
                  ProcessRob(Target)
                  task.wait(0.5) -- Jeda napas loop
              else
                  task.wait(1)
              end
          end
      end)
   end,
})

Rayfield:Notify({
   Title = "Voidline Loaded",
   Content = "Pure Teleport Method Active. No Tweens.",
   Duration = 5
})
