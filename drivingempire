local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Voidline Hub | Driving Empire",
   LoadingTitle = "Direct Workspace Access...",
   LoadingSubtitle = "by Voidline x Specter",
   ConfigurationSaving = { Enabled = true, FileName = "VoidlineDE_FinalFix" }
})

-- [[ SERVICES & REFERENCES ]]
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LP = game.Players.LocalPlayer
local Remotes = require(ReplicatedStorage.Modules.Shared.Remotes)
local CriminalConstants = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalConstants)

_G.AutoFarm = false
_G.FarmDelay = 1.5

-- [[ FUNCTIONS ]]
local function InstantTP(TargetCFrame)
    if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        -- Force Turun dari mobil
        local Hum = LP.Character:FindFirstChildOfClass("Humanoid")
        if Hum and Hum.SeatPart then Hum.Sit = false task.wait(0.1) end
        
        LP.Character:PivotTo(TargetCFrame)
    end
end

-- Fungsi nyari ATM berdasarkan struktur Workspace lu
local function GetAvailableATM()
    local Spawners = workspace:WaitForChild("Game"):WaitForChild("Jobs"):WaitForChild("CriminalATMSpawners"):GetChildren()
    for _, spawner in ipairs(Spawners) do
        -- Masuk ke CriminalATM > ATM
        local CriminalATM = spawner:FindFirstChild("CriminalATM")
        if CriminalATM then
            local ATM = CriminalATM:FindFirstChild("ATM")
            -- Cek status Busted (Module 1/5)
            if ATM and CriminalATM:GetAttribute("State") ~= "Busted" then
                return ATM -- Kita ambil part ATM-nya
            end
        end
    end
    return nil
end

-- Cari Drop Off Point (Sesuai Module 4)
local function GetDropPoint()
    for _, v in ipairs(game:GetService("CollectionService"):GetTagged("CriminalDropOffPoint")) do
        if v:FindFirstChild("Zone") then return v.Zone end
    end
    return nil
end

-- [[ TAB MAIN ]]
local MainTab = Window:CreateTab("Main Farm", 4483362458)

MainTab:CreateToggle({
   Name = "Start Instant Auto Rob",
   CurrentValue = false,
   Flag = "MainFarmToggle",
   Callback = function(Value)
      _G.AutoFarm = Value
      
      task.spawn(function()
          while _G.AutoFarm do
              -- 1. Check Wanted Level (Auto Drop)
              local WantedLevel = LP:GetAttribute(CriminalConstants.PlayerAttributes.CrimesCommitted) or 0
              if WantedLevel >= 5 then
                  local Drop = GetDropPoint()
                  if Drop then
                      InstantTP(Drop.CFrame)
                      task.wait(2)
                  end
              end

              -- 2. Find ATM from Workspace Path
              local TargetATM = GetAvailableATM()
              if TargetATM then
                  -- TP ke PromptAttachment biar pas (Workspace lu)
                  local PromptPos = TargetATM:FindFirstChild("PromptAttachment")
                  local TargetPos = PromptPos and PromptPos.WorldCFrame or TargetATM.CFrame
                  
                  InstantTP(TargetPos * CFrame.new(0, 0, 2))
                  task.wait(0.3)
                  
                  -- BYPASS: Tembak Remote (Target.Parent itu folder CriminalATM)
                  local CriminalATMFolder = TargetATM.Parent
                  Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustStart, CriminalATMFolder)
                  task.wait(0.2)
                  Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustComplete, CriminalATMFolder)
                  
                  task.wait(_G.FarmDelay)
              else
                  task.wait(1)
              end
          end
      end)
   end,
})

MainTab:CreateSlider({
   Name = "Farming Delay",
   Min = 0.5,
   Max = 5,
   CurrentValue = 1.5,
   ValueName = "Detik",
   Callback = function(Value) _G.FarmDelay = Value end,
})

