local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "VoidlineHub | Full Auto V8",
   LoadingTitle = "Cirebon 110M Precision",
   LoadingSubtitle = "by habilyusuf101",
   Theme = "AmberGlow"
})

local LP = game.Players.LocalPlayer
local Remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
_G.AutoFull = false
local lastTarget = nil
local noBillboardTime = 0
local jobStarted = false

-- Koordinat Finish Cirebon (End Job - Checkpoint ke-9)
local CirebonEndCF = CFrame.new(-26471.1445, -212.441071, 33276.8203, -0.0246282816, 0, 0.999696672, 0, 1, 0, -0.999696672, 0, -0.0246282816)

-- Fungsi Ambil Bus
local function GetMyBus()
    return workspace.SpawnedVehicles:FindFirstChild("Jetbus_3_RM _SHD")
end

-- FUNGSI FREEZE/ANCHOR
local function SetFreeze(state)
    local bus = GetMyBus()
    if bus then
        for _, part in pairs(bus:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = state
                if not state then
                    part.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end
            end
        end
    end
end

-- FUNGSI TELEPORT STABIL
local function InstantTP(targetCF)
    local bus = GetMyBus()
    if not bus then return end

    SetFreeze(false) 
    bus:PivotTo(targetCF)
    
    task.wait(0.1)
    for _, part in pairs(bus:GetDescendants()) do
        if part:IsA("BasePart") then
            part.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end
    end
end

-- SCAN BILLBOARD
local function GetActiveStop()
    for _, part in pairs(workspace.Checkpoints:GetChildren()) do
        local bs = part:FindFirstChild("BusStop")
        if bs and bs:IsA("BillboardGui") and bs.Enabled == true then
            return part
        end
    end
    return nil
end

-- --- UI TABS ---
local MainTab = Window:CreateTab("Automation", "play")

MainTab:CreateToggle({
    Name = "Extreme Auto (40s Precision)",
    CurrentValue = false,
    Callback = function(Value)
        _G.AutoFull = Value
        if not Value then 
            lastTarget = nil 
            jobStarted = false
            SetFreeze(false)
        end
        
        while _G.AutoFull do
            local bus = GetMyBus()
            local hum = LP.Character and LP.Character:FindFirstChild("Humanoid")
            
            -- STEP 1: SETUP AWAL
            if not jobStarted then
                Remotes:WaitForChild("SpawnCar"):FireServer("Jetbus_3_RM _SHD")
                task.wait(3)
                bus = GetMyBus()
                
                if bus and bus:FindFirstChild("DriveSeat") then
                    bus.DriveSeat:Sit(hum)
                    task.wait(1.5)
                    
                    local args = {"Baranangsiang_ke_Cirebon1"}
                    Remotes:WaitForChild("StartBusJob"):InvokeServer(unpack(args))
                    task.wait(1)
                    
                    bus.DriveSeat:Sit(hum)
                    jobStarted = true 
                    Rayfield:Notify({Title = "Voidline", Content = "Job Active! Scanning..."})
                end
            end
            
            -- STEP 2: CHECKPOINT HANDLING (DELAY 40s TOTAL)
            local target = GetActiveStop()
            
            if target then
                noBillboardTime = 0 
                
                if target ~= lastTarget then
                    -- 1. TELEPORT KE BILLBOARD
                    InstantTP(target.CFrame)
                    lastTarget = target
                    
                    -- 2. JEDA 2 DETIK BARU KUNCI
                    task.wait(2)
                    SetFreeze(true)
                    
                    -- 3. DELAY 12 DETIK DI CHECKPOINT (DIAM TOTAL)
                    Rayfield:Notify({Title = "Checkpoint", Content = "Locked 12s..."})
                    task.wait(12)
                    
                    SetFreeze(false)
                    
                    -- 4. DELAY 20 DETIK SEBELUM BOLEH PINDAH LAGI
                    Rayfield:Notify({Title = "Security", Content = "Cooldown 20s sebelum TP berikutnya..."})
                    task.wait(20)
                end
            else
                -- STEP 3: LOGIC END POS (HANYA DI AKHIR SETELAH BILLBOARD HILANG)
                if jobStarted then
                    noBillboardTime = noBillboardTime + 1
                    
                    -- Jika Billboard sudah hilang selama 60 detik (1 menit)
                    if noBillboardTime >= 60 then
                        Rayfield:Notify({Title = "Finish", Content = "Semua Checkpoint Selesai. Teleport ke End Position!"})
                        
                        -- Teleport ke Koordinat Cirebon (Checkpoint 9 / Akhir)
                        InstantTP(CirebonEndCF)
                        task.wait(15) -- Nunggu payout masuk
                        
                        -- RESET SEMUA UNTUK LOOP BERIKUTNYA
                        jobStarted = false
                        lastTarget = nil
                        noBillboardTime = 0
                        if bus then bus:Destroy() end 
                    end
                end
            end
            
            task.wait(1)
        end
    end
})

Rayfield:Notify({Title = "Voidline Loaded", Content = "Logic V8 (12s Freeze + 20s Cooldown) Aktif!"})
