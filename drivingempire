local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Voidline",
   Title = "v1 - Ultimate Criminal",
   LoadingTitle = "Syncing All Modules...",
   LoadingSubtitle = "by Voidline",
   ConfigurationSaving = { Enabled = true, FileName = "Voidline_Ultimate" }
})

-- [[ SERVICES & MODULES ]]
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LP = game.Players.LocalPlayer
local Remotes = require(ReplicatedStorage.Modules.Shared.Remotes)
local CriminalConstants = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalConstants)
local CriminalUtil = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalUtil)
local ATMJobTask = require(ReplicatedStorage.Modules.Client.Jobs.Tasks.CriminalATMJobTask)

_G.AutoFarm = false

-- [[ LOGIC HELPERS ]]

local function IsSecurityHunting()
    -- Nangkep logic dari module CriminalWantedState
    local expire = LP:GetAttribute(CriminalConstants.PlayerAttributes.CriminalExpireEpoch)
    local paused = LP:GetAttribute(CriminalConstants.PlayerAttributes.CriminalPausedEpoch)
    
    -- Kalau statusnya lagi "Security is on to you", kita harus nunggu
    if paused or (expire and expire > workspace:GetServerTimeNow()) then
        return true
    end
    return false
end

local function GetTargetATM()
    local Spawners = workspace.Game.Jobs.CriminalATMSpawners:GetChildren()
    for _, spawner in ipairs(Spawners) do
        local CriminalATM = spawner:FindFirstChild("CriminalATM")
        -- Cek state apakah ATM sudah dibust (Attribute State)
        if CriminalATM and CriminalATM:GetAttribute("State") ~= "Busted" then
            local ATM = CriminalATM:FindFirstChild("ATM")
            if ATM then return ATM end
        end
    end
    return nil
end

local function ProcessRob(TargetATM)
    local CriminalATMFolder = TargetATM.Parent
    
    -- 1. DELAY DULU SEBELUM TP (Method Lu)
    task.wait(2.5) 
    
    -- 2. PURE TELEPORT
    LP.Character:PivotTo(TargetATM.CFrame * CFrame.new(0, 0, 3))
    
    -- 3. JEDA SINKRONISASI (Bypass Travel Speed)
    task.wait(3) 
    
    -- 4. START BUSTING
    local sStart = Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustStart, CriminalATMFolder)
    
    if sStart then
        -- 5. WAIT BUST TIME (Dinamis: nanya ke module CriminalUtil)
        -- Ini biar gak kena "Exploiting Bust Time"
        local waitTime = CriminalUtil.GetATMBustTime(LP) or 5.2
        task.wait(waitTime + 0.3) 
        
        -- 6. COMPLETE
        Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustComplete, CriminalATMFolder)
    end
end

-- [[ UI ]]
local MainTab = Window:CreateTab("Auto Farm", 4483362458)

MainTab:CreateToggle({
   Name = "Ultimate Criminal Cycle",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoFarm = Value
      
      task.spawn(function()
          while _G.AutoFarm do
              -- Emergency Dismount
              local Hum = LP.Character:FindFirstChildOfClass("Humanoid")
              if Hum and Hum.SeatPart then Hum.Sit = false task.wait(0.3) end

              -- 1. CEK SECURITY (Logic Bypass)
              if IsSecurityHunting() then
                  Rayfield:Notify({Title = "Voidline", Content = "Security detected! Cooling down..."})
                  repeat task.wait(1) until not IsSecurityOnUs() or not _G.AutoFarm
              end

              -- 2. CEK BINTANG (Setor kalau 5)
              local Stars = CriminalUtil.GetStarValue(LP) or 0
              if Stars >= 5 then
                  local DropPoints = workspace.Game.Jobs.CriminalDropOffPoints:GetChildren()
                  if #DropPoints > 0 then
                      local Point = DropPoints[1]
                      LP.Character:PivotTo(Point.Zone.CFrame)
                      task.wait(2)
                      ATMJobTask.AttemptCompleteJob(Point)
                      task.wait(1)
                  end
              end

              -- 3. CARI & ROB ATM
              local Target = GetTargetATM()
              if Target then
                  pcall(function() ProcessRob(Target) end)
                  task.wait(1)
              else
                  task.wait(2) -- Nunggu respawn
              end
              
              if not _G.AutoFarm then break end
          end
      end)
   end,
})

Rayfield:Notify({
   Title = "Voidline Ready",
   Content = "Semua modul berhasil disinkronisasi!",
   Duration = 5
})
