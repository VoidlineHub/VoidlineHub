local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Voidline",
   Title = "v1 - Ultimate Criminal Sync",
   LoadingTitle = "Bypassing Configs...",
   LoadingSubtitle = "by Voidline",
   ConfigurationSaving = { Enabled = true, FileName = "Voidline_Ultimate_V2" }
})

-- [[ SERVICES & MODULES ]]
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LP = game.Players.LocalPlayer
local Remotes = require(ReplicatedStorage.Modules.Shared.Remotes)
local CriminalConstants = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalConstants)
local CriminalUtil = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalUtil)
local ATMJobTask = require(ReplicatedStorage.Modules.Client.Jobs.Tasks.CriminalATMJobTask)

_G.AutoFarm = false

-- [[ LOGIC HELPERS ]]

-- Logic Pengecekan Server ala Lu
local function GetServerType()
    return (#game.Players:GetPlayers() <= 1) and "Private" or "Public"
end

local function IsSecurityHunting()
    local expire = LP:GetAttribute(CriminalConstants.PlayerAttributes.CriminalExpireEpoch)
    local paused = LP:GetAttribute(CriminalConstants.PlayerAttributes.CriminalPausedEpoch)
    if paused or (expire and expire > workspace:GetServerTimeNow()) then
        return true
    end
    return false
end

local function GetTargetATM()
    -- Langsung nembak ke Spawners Folder
    local SpawnerPath = workspace:WaitForChild("Game"):WaitForChild("Jobs"):WaitForChild("CriminalATMSpawners")
    local Spawners = SpawnerPath:GetChildren()
    
    for _, spawner in ipairs(Spawners) do
        local CriminalATM = spawner:FindFirstChild("CriminalATM")
        if CriminalATM and CriminalATM:GetAttribute("State") ~= "Busted" then
            local ATM = CriminalATM:FindFirstChild("ATM")
            if ATM then return ATM end
        end
    end
    return nil
end

local function ProcessRob(TargetATM)
    local CriminalATMFolder = TargetATM.Parent
    
    -- Jeda dikit biar server gak narik balik posisi lu (Rubberband)
    task.wait(1) 
    
    -- TELEPORT: Pake offset biar ga nyangkut (Sesuai logic Killer v2)
    LP.Character:PivotTo(TargetATM.CFrame * CFrame.new(0, 0, 3.5))
    
    -- JEDA SINKRONISASI: Wajib 3 detik biar anticheat travel speed ga nendang
    task.wait(3.5) 
    
    -- START BUSTING
    local sStart, rStart = Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustStart, CriminalATMFolder)
    
    if sStart then
        -- WAIT BUST TIME: Dinamis nanya ke module game
        local waitTime = CriminalUtil.GetATMBustTime(LP) or 5.2
        task.wait(waitTime + 0.8) -- Ditambah buffer aman
        
        -- COMPLETE
        Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustComplete, CriminalATMFolder)
    else
        warn("Gagal Start: " .. tostring(rStart))
    end
end

-- [[ UI ]]
local MainTab = Window:CreateTab("Auto Farm", 4483362458)

MainTab:CreateToggle({
   Name = "Ultimate Cycle (Auto-Sync Server)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoFarm = Value
      
      task.spawn(function()
          while _G.AutoFarm do
              -- Info Server Type
              local currentMode = GetServerType()
              
              -- Emergency Dismount
              local Hum = LP.Character:FindFirstChildOfClass("Humanoid")
              if Hum and Hum.SeatPart then Hum.Sit = false task.wait(0.5) end

              -- 1. CEK SECURITY
              if IsSecurityHunting() then
                  Rayfield:Notify({Title = "Voidline", Content = "Security detected! Cooling down in "..currentMode.." mode."})
                  repeat task.wait(1) until not IsSecurityHunting() or not _G.AutoFarm
              end

              -- 2. CEK BINTANG (Setor kalau 5)
              local Stars = CriminalUtil.GetStarValue(LP) or 0
              if Stars >= 5 then
                  local DropPoints = workspace.Game.Jobs.CriminalDropOffPoints:GetChildren()
                  if #DropPoints > 0 then
                      local Point = DropPoints[1]
                      LP.Character:PivotTo(Point.Zone.CFrame * CFrame.new(0, 2, 0))
                      task.wait(3) -- Delay setor biar gak kick
                      ATMJobTask.AttemptCompleteJob(Point)
                      task.wait(1)
                  end
              end

              -- 3. CARI & ROB ATM
              local Target = GetTargetATM()
              if Target then
                  -- Eksekusi dengan pcall biar kalau satu ATM gagal, gak ngerusak loop
                  pcall(function()
                      ProcessRob(Target)
                  end)
                  task.wait(1.5)
              else
                  task.wait(3) -- Nunggu respawn lebih lama biar server refresh
              end
              
              if not _G.AutoFarm then break end
          end
      end)
   end,
})

Rayfield:Notify({
   Title = "Voidline Ready",
   Content = "Server Type Detected: " .. GetServerType(),
   Duration = 5
})
