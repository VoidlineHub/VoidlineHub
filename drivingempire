local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Voidline Hub | Driving Empire",
   LoadingTitle = "Instant Teleport Active",
   LoadingSubtitle = "by Voidline x Specter",
   ConfigurationSaving = { Enabled = true, FileName = "VoidlineDE_Instant" }
})

-- [[ SERVICES & MODULES ]]
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CollectionService = game:GetService("CollectionService")
local LP = game.Players.LocalPlayer

-- Ambil Remote dari Module yang lu kasih tadi
local Remotes = require(ReplicatedStorage.Modules.Shared.Remotes)
local CriminalConstants = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalConstants)

-- Variables
_G.AutoFarm = false
_G.FarmDelay = 1.5 -- Jeda antar ATM biar gak kena kick

-- [[ FUNCTIONS ]]
local function InstantTP(TargetCFrame)
    if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        -- Force Turun dari mobil (Module 5 requirement)
        local Hum = LP.Character:FindFirstChildOfClass("Humanoid")
        if Hum and Hum.SeatPart then Hum.Sit = false task.wait(0.2) end
        
        -- Langsung teleport ke koordinat
        LP.Character:PivotTo(TargetCFrame)
    end
end

local function GetTargetATM()
    local ATMs = CollectionService:GetTagged("CriminalATMClient")
    for _, v in ipairs(ATMs) do
        if v.Parent and v.Parent:GetAttribute("State") ~= "Busted" then
            return v
        end
    end
    return nil
end

local function GetDropPoint()
    local Points = CollectionService:GetTagged("CriminalDropOffPoint")
    for _, v in ipairs(Points) do
        if v:FindFirstChild("Zone") then
            return v.Zone
        end
    end
    return nil
end

-- [[ MAIN TAB ]]
local MainTab = Window:CreateTab("Auto Farm", 4483362458)

MainTab:CreateToggle({
   Name = "Instant Auto Rob (Teleport)",
   CurrentValue = false,
   Flag = "AutoRobToggle", -- Flag unik buat config
   Callback = function(Value)
      _G.AutoFarm = Value
      
      task.spawn(function()
          while _G.AutoFarm do
              -- 1. Cek Bintang (Kalau Bintang 5 ke Drop Point)
              local WantedLevel = LP:GetAttribute(CriminalConstants.PlayerAttributes.CrimesCommitted) or 0
              if WantedLevel >= 5 then
                  local Drop = GetDropPoint()
                  if Drop then
                      Rayfield:Notify({Title = "Voidline", Content = "Setor Duit dulu bre..."})
                      InstantTP(Drop.CFrame)
                      task.wait(2) -- Jeda biar server register lu di zona drop
                  end
              end

              -- 2. Cari ATM
              local Target = GetTargetATM()
              if Target then
                  -- Teleport langsung ke ATM
                  InstantTP(Target.CFrame * CFrame.new(0, 0, 3))
                  task.wait(0.3)
                  
                  -- Tembak Remote (Bypass ProximityPrompt)
                  Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustStart, Target.Parent)
                  task.wait(0.2)
                  Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustComplete, Target.Parent)
                  
                  Rayfield:Notify({Title = "Voidline", Content = "ATM Berhasil Dirampok!"})
                  task.wait(_G.FarmDelay) -- Jeda antar ATM (slider)
              else
                  task.wait(1) -- Nunggu ATM spawn
              end
          end
      end)
   end,
})

-- Fix Slider: Sekarang ngatur jeda/delay biar gak error
MainTab:CreateSlider({
   Name = "Farming Delay (Detik)",
   Min = 0.5,
   Max = 5,
   CurrentValue = 1.5,
   Color = Color3.fromRGB(255, 128, 0),
   Increment = 0.1,
   ValueName = "Detik",
   Flag = "DelaySlider", 
   Callback = function(Value)
      _G.FarmDelay = Value
   end,
})

Rayfield:Notify({
   Title = "Voidline Hub Ready",
   Content = "Instant Teleport & Remote Bypass Loaded!",
   Duration = 5,
})
