local Window = Rayfield:CreateWindow({
   Name = "VoidlineHub",
   Title = "v10.2 - Premium CDID Criminal",
   LoadingTitle = "VoidlineHub Loading...",
   LoadingSubtitle = "by Voidline",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "Voidline_Config",
