local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "VoidlineHub | Full Auto V9",
   LoadingTitle = "Cirebon 110M High-Security",
   LoadingSubtitle = "by habilyusuf101",
   Theme = "AmberGlow"
})

local LP = game.Players.LocalPlayer
local Remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
_G.AutoFull = false
local lastTarget = nil
local noBillboardTime = 0
local jobStarted = false

-- Koordinat Finish Cirebon (Checkpoint ke-9)
local CirebonEndCF = CFrame.new(-26471.1445, -212.441071, 33276.8203, -0.0246282816, 0, 0.999696672, 0, 1, 0, -0.999696672, 0, -0.0246282816)

-- Fungsi Ambil Bus
local function GetMyBus()
    return workspace.SpawnedVehicles:FindFirstChild("Jetbus_3_RM _SHD")
end

-- FUNGSI FREEZE/ANCHOR
local function SetFreeze(state)
    local bus = GetMyBus()
    if bus then
        for _, part in pairs(bus:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = state
                if not state then
                    part.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end
            end
        end
    end
end

-- FUNGSI TELEPORT STABIL (DITAMBAH FORCE POSITION)
local function InstantTP(targetCF)
    local bus = GetMyBus()
    if not bus then return end

    SetFreeze(false) 
    task.wait(0.1)
    
    -- Coba teleport berkali-kali dalam waktu singkat biar server gak nolak
    for i = 1, 3 do
        bus:PivotTo(targetCF)
        task.wait(0.05)
    end
    
    -- Bersihkan gaya gerak
    for _, part in pairs(bus:GetDescendants()) do
        if part:IsA("BasePart") then
            part.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end
    end
end

-- SCAN BILLBOARD
local function GetActiveStop()
    for _, part in pairs(workspace.Checkpoints:GetChildren()) do
        local bs = part:FindFirstChild("BusStop")
        if bs and bs:IsA("BillboardGui") and bs.Enabled == true then
            return part
        end
    end
    return nil
end

-- --- UI TABS ---
local MainTab = Window:CreateTab("Automation", "play")

MainTab:CreateToggle({
    Name = "Extreme Auto (Fire -> Spawn)",
    CurrentValue = false,
    Callback = function(Value)
        _G.AutoFull = Value
        if not Value then 
            lastTarget = nil 
            jobStarted = false
            SetFreeze(false)
        end
        
        while _G.AutoFull do
            local bus = GetMyBus()
            local hum = LP.Character and LP.Character:FindFirstChild("Humanoid")
            
            -- STEP 1: SETUP (URUTAN REQUEST: FIRE -> SPAWN -> NAIK)
            if not jobStarted then
                -- 1. Fire Remote Dulu
                Rayfield:Notify({Title = "Remote", Content = "Firing Job Remote..."})
                local args = {"Baranangsiang_ke_Cirebon1"}
                Remotes:WaitForChild("StartBusJob"):InvokeServer(unpack(args))
                task.wait(1)
                
                -- 2. Spawn Bus
                Remotes:WaitForChild("SpawnCar"):FireServer("Jetbus_3_RM _SHD")
                task.wait(3)
                bus = GetMyBus()
                
                -- 3. Naik Bus
                if bus and bus:FindFirstChild("DriveSeat") then
                    bus.DriveSeat:Sit(hum)
                    jobStarted = true 
                    Rayfield:Notify({Title = "Voidline", Content = "Bus Ready! Job Synchronized."})
                end
            end
            
            -- STEP 2: CHECKPOINT HANDLING (DELAY 15s FREEZE + 20s WAIT)
            local target = GetActiveStop()
            
            if target then
                noBillboardTime = 0 
                
                if target ~= lastTarget then
                    -- 1. TELEPORT KE BILLBOARD
                    InstantTP(target.CFrame)
                    lastTarget = target
                    
                    -- 2. JEDA 2 DETIK BARU KUNCI (Mastiin posisi pas)
                    task.wait(2)
                    SetFreeze(true)
                    
                    -- 3. DELAY 15 DETIK DI CHECKPOINT (FREEZE)
                    Rayfield:Notify({Title = "Status", Content = "Freeze 15s di Checkpoint..."})
                    task.wait(15)
                    
                    SetFreeze(false)
                    
                    -- 4. DELAY 20 DETIK SEBELUM TP LAGI
                    Rayfield:Notify({Title = "Status", Content = "Unfreeze, Delay 20s buat TP Berikutnya..."})
                    task.wait(20)
                end
            else
                -- STEP 3: END JOB LOGIC
                if jobStarted then
                    noBillboardTime = noBillboardTime + 1
                    
                    if noBillboardTime >= 60 then
                        Rayfield:Notify({Title = "Finish", Content = "All Checkpoints Done. Gas End Pos!"})
                        InstantTP(CirebonEndCF)
                        task.wait(15)
                        
                        -- RESET BUAT LOOP BARU
                        jobStarted = false
                        lastTarget = nil
                        noBillboardTime = 0
                        if bus then bus:Destroy() end 
                    end
                end
            end
            
            task.wait(1)
        end
    end
})

Rayfield:Notify({Title = "Voidline Loaded", Content = "Method Fire-Spawn & 15s+20s Delay Aktif!"})
