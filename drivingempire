-- Gabungan 9 Module Driving Empire

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Voidline Hub | Driving Empire",
   LoadingTitle = "Bypassing Proximity Logic...",
   LoadingSubtitle = "by Voidline x Specter",
   ConfigurationSaving = { Enabled = true, FileName = "VoidlineDE_Ultra" }
})

-- [[ SERVICES & MODULES ]]
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CollectionService = game:GetService("CollectionService")
local TweenService = game:GetService("TweenService")
local LP = game.Players.LocalPlayer

-- Mengambil Remote & Constant dari Module 5 & 1
local Remotes = require(ReplicatedStorage.Modules.Shared.Remotes)
local CriminalConstants = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalConstants)
local JobConstants = require(ReplicatedStorage.Modules.Shared.Jobs.JobsConstants)

-- Variables
_G.AutoFarm = false
_G.TPSpeed = 180

-- [[ FUNCTIONS ]]
local function SafeTween(TargetCFrame)
    local Root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not Root then return end
    
    local Dist = (TargetCFrame.p - Root.Position).Magnitude
    local Time = Dist / _G.TPSpeed
    local Tween = TweenService:Create(Root, TweenInfo.new(Time, Enum.EasingStyle.Linear), {CFrame = TargetCFrame})
    Tween:Play()
    return Tween
end

local function GetTargetATM()
    for _, v in ipairs(CollectionService:GetTagged("CriminalATMClient")) do
        if v.Parent and v.Parent:GetAttribute("State") ~= "Busted" then
            return v
        end
    end
    return nil
end

local function GetDropPoint()
    for _, v in ipairs(CollectionService:GetTagged("CriminalDropOffPoint")) do
        if v:FindFirstChild("Zone") then
            return v.Zone
        end
    end
    return nil
end

-- [[ MAIN TAB ]]
local MainTab = Window:CreateTab("Auto Farm", 4483362458)

MainTab:CreateToggle({
   Name = "Instant Auto Rob (No Prompt)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoFarm = Value
      
      task.spawn(function()
          while _G.AutoFarm do
              -- 1. Check Wanted Level (Module 4 Logic)
              local WantedLevel = LP:GetAttribute(CriminalConstants.PlayerAttributes.CrimesCommitted) or 0
              if WantedLevel >= 5 then
                  local Drop = GetDropPoint()
                  if Drop then
                      Rayfield:Notify({Title = "Voidline", Content = "Bintang Penuh! Meluncur ke Drop Point..."})
                      local T = SafeTween(Drop.CFrame)
                      if T then T.Completed:Wait() end
                      task.wait(1)
                      -- Auto-finish job via Zone detection (Module 4)
                  end
              end

              -- 2. Find & Rob ATM (Module 5 Logic)
              local Target = GetTargetATM()
              if Target then
                  -- Force Dismount (Biar gak nyangkut di mobil)
                  local Hum = LP.Character:FindFirstChildOfClass("Humanoid")
                  if Hum and Hum.SeatPart then Hum.Sit = false end
                  
                  -- Tween ke ATM
                  local T = SafeTween(Target.CFrame * CFrame.new(0, 0, 3))
                  if T then T.Completed:Wait() end
                  
                  -- BYPASS: Langsung Tembak Remote (Script 5)
                  task.wait(0.5)
                  Rayfield:Notify({Title = "Voidline", Content = "Attempting Instant Rob..."})
                  
                  -- Tembak Remote Start & Complete berturutan
                  Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustStart, Target.Parent)
                  task.wait(0.5) -- Jeda dikit biar gak sus
                  Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustComplete, Target.Parent)
                  
                  task.wait(1) -- Delay antar ATM
              else
                  task.wait(2)
              end
          end
      end)
   end,
})

MainTab:CreateSlider({
   Name = "TP Speed",
   Min = 100,
   Max = 400,
   CurrentValue = 180,
   Callback = function(Value) _G.TPSpeed = Value end,
})

