local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "VoidlineHub | God Mode V4",
   LoadingTitle = "Cirebon 110M Extreme",
   LoadingSubtitle = "by habilyusuf101",
   Theme = "AmberGlow"
})

local LP = game.Players.LocalPlayer
local Remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
_G.AutoFull = false
local lastTarget = nil

-- Koordinat Finish Cirebon
local CirebonEndCF = CFrame.new(-26471.1445, -212.441071, 33276.8203, -0.0246282816, 0, 0.999696672, 0, 1, 0, -0.999696672, 0, -0.0246282816)

-- Fungsi Ambil Bus
local function GetMyBus()
    return workspace.SpawnedVehicles:FindFirstChild("Jetbus_3_RM _SHD")
end

-- FUNGSI FREEZE BUS (Biar gak maju sendiri)
local function FreezeBus(state)
    local bus = GetMyBus()
    if bus then
        for _, part in pairs(bus:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = state
                if not state then -- Jika unfreeze, bersihkan velocity
                    part.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end
            end
        end
    end
end

-- FUNGSI TELEPORT STABIL
local function InstantTP(targetCF)
    local bus = GetMyBus()
    if not bus then return end

    FreezeBus(false) -- Lepas anchor dulu buat pindah
    bus:PivotTo(targetCF)
    
    task.wait(0.1)
    for _, part in pairs(bus:GetDescendants()) do
        if part:IsA("BasePart") then
            part.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end
    end
end

-- SCAN CHECKPOINT
local function GetActiveStop()
    for _, part in pairs(workspace.Checkpoints:GetChildren()) do
        local bs = part:FindFirstChild("BusStop")
        if bs and bs:IsA("BillboardGui") and bs.Enabled == true then
            return part
        end
    end
    return nil
end

-- --- UI TABS ---
local MainTab = Window:CreateTab("Automation", "play")

MainTab:CreateToggle({
    Name = "Extreme Loop 110M (Delay 30s)",
    CurrentValue = false,
    Callback = function(Value)
        _G.AutoFull = Value
        if not Value then 
            lastTarget = nil 
            FreezeBus(false)
        end
        
        while _G.AutoFull do
            local bus = GetMyBus()
            
            -- STEP: DOUBLE SPAWN & START JOB
            if not bus or (LP.Character.Humanoid.SeatPart == nil) then
                -- Spawn 1
                Remotes.SpawnCar:FireServer("Jetbus_3_RM _SHD")
                task.wait(2)
                -- Spawn 2 (Sesuai Method Kamu)
                Remotes.SpawnCar:FireServer("Jetbus_3_RM _SHD")
                task.wait(2)
                
                bus = GetMyBus()
                if bus and bus:FindFirstChild("DriveSeat") then
                    bus.DriveSeat:Sit(LP.Character.Humanoid)
                    task.wait(2)
                    
                    -- Fire Remote Start Job
                    Rayfield:Notify({Title = "Remote", Content = "Starting 110M Route..."})
                    Remotes.StartBusJob:InvokeServer("Baranangsiang_ke_Cirebon1")
                    task.wait(1)
                end
            end
            
            -- STEP: CHECKPOINT HANDLING
            local target = GetActiveStop()
            if target and target ~= lastTarget then
                InstantTP(target.CFrame)
                lastTarget = target
                
                -- PAKSA BERHENTI (Freeze) biar gak maju sendiri
                FreezeBus(true)
                Rayfield:Notify({Title = "Checkpoint", Content = "Bus Locked! Waiting 30s..."})
                
                task.wait(30) -- Delay naik ke 30 detik sesuai request
                
                FreezeBus(false) -- Lepas lagi biar sistem game detect kita lewat
                task.wait(1)
            end
            
            if not target then
                lastTarget = nil
            end
            
            -- STEP: FINISH / END SHIFT DETECTION
            local gui = LP.PlayerGui:FindFirstChild("BusJobGUI")
            local isFinishing = false
            
            if gui and gui:FindFirstChild("JobStatusFrame") and gui.JobStatusFrame.Visible then
                local label = gui.JobStatusFrame.InfoLabel.Text
                if label:find("Cirebon") or label:find("Harjamukti") or label:find("Selesai") then
                    isFinishing = true
                end
            end
            
            -- Kalau rute sudah tidak ada billboard dan terdeteksi finish
            if isFinishing and not target then
                Rayfield:Notify({Title = "Finish", Content = "Heading to End Point..."})
                InstantTP(CirebonEndCF)
                task.wait(5)
                
                -- End Shift / Reset buat Loop
                Remotes.EndBusJob:InvokeServer() 
                task.wait(3)
                if bus then bus:Destroy() end -- Hapus bus lama biar bersih buat loop berikutnya
            end
            
            task.wait(1)
        end
    end
})

Rayfield:Notify({Title = "Voidline Loaded", Content = "Method Double-Spawn & Freeze Aktif!"})
