local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "VoidlineHub | God Mode V5",
   LoadingTitle = "Cirebon 110M High-Security",
   LoadingSubtitle = "by habilyusuf101",
   Theme = "AmberGlow"
})

local LP = game.Players.LocalPlayer
local Remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
_G.AutoFull = false
local lastTarget = nil
local noBillboardTime = 0

-- Koordinat Finish Cirebon (Checkpoint ke-9 / End Job)
local CirebonEndCF = CFrame.new(-26471.1445, -212.441071, 33276.8203, -0.0246282816, 0, 0.999696672, 0, 1, 0, -0.999696672, 0, -0.0246282816)

-- Fungsi Ambil Bus
local function GetMyBus()
    return workspace.SpawnedVehicles:FindFirstChild("Jetbus_3_RM _SHD")
end

-- FUNGSI FREEZE/ANCHOR
local function SetFreeze(state)
    local bus = GetMyBus()
    if bus then
        for _, part in pairs(bus:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = state
                if not state then
                    part.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end
            end
        end
    end
end

-- FUNGSI TELEPORT STABIL
local function InstantTP(targetCF)
    local bus = GetMyBus()
    if not bus then return end

    SetFreeze(false) -- Lepas freeze dulu
    bus:PivotTo(targetCF)
    
    task.wait(0.1)
    for _, part in pairs(bus:GetDescendants()) do
        if part:IsA("BasePart") then
            part.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end
    end
end

-- SCAN BILLBOARD
local function GetActiveStop()
    for _, part in pairs(workspace.Checkpoints:GetChildren()) do
        local bs = part:FindFirstChild("BusStop")
        if bs and bs:IsA("BillboardGui") and bs.Enabled == true then
            return part
        end
    end
    return nil
end

-- --- UI TABS ---
local MainTab = Window:CreateTab("Automation", "play")

MainTab:CreateToggle({
    Name = "Extreme Full Auto (Lompat-Duduk Method)",
    CurrentValue = false,
    Callback = function(Value)
        _G.AutoFull = Value
        if not Value then 
            lastTarget = nil 
            SetFreeze(false)
        end
        
        while _G.AutoFull do
            local bus = GetMyBus()
            local hum = LP.Character and LP.Character:FindFirstChild("Humanoid")
            
            -- STEP 1: SETUP (SPAWN, SIT, JUMP, SIT, REMOTE)
            if not bus or (hum and hum.SeatPart == nil) then
                if not bus then
                    Remotes.SpawnCar:FireServer("Jetbus_3_RM _SHD")
                    task.wait(3)
                    bus = GetMyBus()
                end
                
                if bus and bus:FindFirstChild("DriveSeat") then
                    -- 1. Duduk Pertama
                    bus.DriveSeat:Sit(hum)
                    task.wait(1)
                    -- 2. Lompat
                    hum.Jump = true
                    task.wait(0.5)
                    -- 3. Duduk Lagi
                    bus.DriveSeat:Sit(hum)
                    task.wait(1)
                    -- 4. Fire Remote
                    Remotes.StartBusJob:InvokeServer("Baranangsiang_ke_Cirebon1")
                    Rayfield:Notify({Title = "Setup", Content = "Lompat-Duduk Done! Job Started."})
                    task.wait(1)
                end
            end
            
            -- STEP 2: CHECKPOINT HANDLING
            local target = GetActiveStop()
            
            if target then
                noBillboardTime = 0 -- Reset timer kalau billboard ada
                
                if target ~= lastTarget then
                    -- Teleport dulu
                    InstantTP(target.CFrame)
                    lastTarget = target
                    
                    -- Delay 2 detik baru Freeze
                    task.wait(2)
                    SetFreeze(true)
                    
                    Rayfield:Notify({Title = "Checkpoint", Content = "Bus Frozen! Waiting 30s..."})
                    task.wait(30) -- Delay 30 detik sesuai request
                    
                    SetFreeze(false)
                    task.wait(1)
                end
            else
                -- STEP 3: LOGIC NO-BILLBOARD (END JOB)
                noBillboardTime = noBillboardTime + 1
                
                -- Jika Billboard hilang selama 60 detik (1 menit)
                if noBillboardTime >= 60 then
                    Rayfield:Notify({Title = "Finish", Content = "Billboard hilang 1 menit. TP ke End Pos."})
                    InstantTP(CirebonEndCF)
                    task.wait(10) -- Nunggu payout
                    
                    -- Reset buat Loop berikutnya
                    noBillboardTime = 0
                    lastTarget = nil
                    if bus then bus:Destroy() end 
                end
            end
            
            task.wait(1) -- Tick rate tiap 1 detik
        end
    end
})

Rayfield:Notify({Title = "Voidline Loaded", Content = "Method V5: Lompat-Duduk & Auto-End Aktif!"})
