})

FarmTab:CreateInput({
    Name = "Task 4: Robbery Cooldown",
    PlaceholderText = "Current: 5",
    Callback = function(Text) _G.Delays.Task4 = tonumber(Text) or 5 end
})

FarmTab:CreateInput({
    Name = "Task 7: Platform Loading",
    PlaceholderText = "Current: 0.8",
    Callback = function(Text) _G.Delays.Task7 = tonumber(Text) or 0.8 end
})

-- [[ AUTO REFRESH STATS ]]
task.spawn(function()
    while true do
        ProgressLabel:Set("Bag progress: " .. GetMoneyBagCount() .. " / " .. _G.BagLimit)
        task.wait(1)
    end
end)

