local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "VoidlineHub | Idle",
   LoadingTitle = "Bus driving indonesia",
   LoadingSubtitle = "by VoidLineHub",
   Theme = "AmberGlow"
})

local LP = game.Players.LocalPlayer
local Remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
_G.AutoFull = false
local lastTarget = nil
local noBillboardTime = 0
local jobStarted = false

-- Koordinat Finish Cirebon (End Job)
local CirebonEndCF = CFrame.new(-26471.1445, -212.441071, 33276.8203, -0.0246282816, 0, 0.999696672, 0, 1, 0, -0.999696672, 0, -0.0246282816)

local function UpdateStatus(msg)
    Window:Modify({Name = "VoidlineHub | " .. msg})
end

local function GetMyBus()
    return workspace.SpawnedVehicles:FindFirstChild("Jetbus_3_RM _SHD")
end

local function SetFreeze(state)
    local bus = GetMyBus()
    if bus then
        for _, part in pairs(bus:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = state
                if not state then
                    part.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end
            end
        end
    end
end

local function InstantTP(targetCF)
    local bus = GetMyBus()
    if not bus then return end
    SetFreeze(false) 
    task.wait(0.1)
    for i = 1, 3 do
        bus:PivotTo(targetCF)
        task.wait(0.05)
    end
end

local function GetActiveStop()
    for _, part in pairs(workspace.Checkpoints:GetChildren()) do
        local bs = part:FindFirstChild("BusStop")
        if bs and bs:IsA("BillboardGui") and bs.Enabled == true then
            return part
        end
    end
    return nil
end

local MainTab = Window:CreateTab("Automation", "play")

MainTab:CreateToggle({
    Name = "Silent Auto (90s Delay)",
    CurrentValue = false,
    Callback = function(Value)
        _G.AutoFull = Value
        if not Value then 
            lastTarget = nil 
            jobStarted = false
            SetFreeze(false)
            UpdateStatus("Idle")
        end
        
        while _G.AutoFull do
            local bus = GetMyBus()
            local hum = LP.Character and LP.Character:FindFirstChild("Humanoid")
            
            -- STEP 1: SETUP
            if not jobStarted then
                UpdateStatus("Spawning Bus...")
                Remotes:WaitForChild("SpawnCar"):FireServer("Jetbus_3_RM _SHD")
                task.wait(3)
                bus = GetMyBus()
                
                if bus and bus:FindFirstChild("DriveSeat") then
                    bus.DriveSeat:Sit(hum)
                    task.wait(1.5)
                    
                    UpdateStatus("Firing Job...")
                    Remotes:WaitForChild("StartBusJob"):InvokeServer("Baranangsiang_ke_Cirebon1")
                    task.wait(1)
                    
                    hum.Jump = true
                    task.wait(1)
                    
                    Remotes:WaitForChild("SpawnCar"):FireServer("Jetbus_3_RM _SHD")
                    task.wait(3)
                    bus = GetMyBus() 
                    
                    if bus and bus:FindFirstChild("DriveSeat") then
                        bus.DriveSeat:Sit(hum)
                        jobStarted = true
                    end
                end
            end
            
            -- STEP 2: CHECKPOINT (TOTAL 90s)
            local target = GetActiveStop()
            if target then
                noBillboardTime = 0 
                if target ~= lastTarget then
                    InstantTP(target.CFrame)
                    lastTarget = target
                    task.wait(2)
                    SetFreeze(true) 
                    
                    -- Timer 1: Freeze 30s
                    for i = 30, 1, -1 do
                        if not _G.AutoFull then break end
                        UpdateStatus("FREEZE: " .. i .. "s")
                        task.wait(1)
                    end
                    
                    SetFreeze(false)
                    
                    -- Timer 2: Cooldown 60s
                    for i = 60, 1, -1 do
                        if not _G.AutoFull then break end
                        UpdateStatus("COOLDOWN: " .. i .. "s")
                        task.wait(1)
                    end
                end
            else
                -- STEP 3: END JOB
                if jobStarted then
                    noBillboardTime = noBillboardTime + 1
                    UpdateStatus("Waiting Finish: " .. (40 - noBillboardTime) .. "s")
                    
                    if noBillboardTime >= 40 then
                        UpdateStatus("TP to End Pos")
                        InstantTP(CirebonEndCF)
                        task.wait(2)
                        SetFreeze(true)
                        
                        -- Payout Timer 90s
                        for i = 90, 1, -1 do
                            if not _G.AutoFull then break end
                            UpdateStatus("PAYOUT WAIT: " .. i .. "s")
                            task.wait(1)
                        end
                        
                        SetFreeze(false)
                        jobStarted = false
                        lastTarget = nil
                        noBillboardTime = 0
                        if bus then bus:Destroy() end 
                        task.wait(5)
                    end
                end
            end
            task.wait(1)
        end
    end
})

UpdateStatus("Ready")
