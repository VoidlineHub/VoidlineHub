local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Voidline",
   Title = "v1.3 - Radar Edition",
   LoadingTitle = "Loading Criminal Modules...",
   LoadingSubtitle = "by Voidline",
   ConfigurationSaving = { Enabled = true, FileName = "Voidline_Ultimate" }
})

-- [[ SERVICES & MODULES ]]
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LP = game.Players.LocalPlayer
local Remotes = require(ReplicatedStorage.Modules.Shared.Remotes)
local CriminalConstants = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalConstants)
local CriminalUtil = require(ReplicatedStorage.Modules.Shared.Jobs.Criminal.CriminalUtil)
local ATMJobTask = require(ReplicatedStorage.Modules.Client.Jobs.Tasks.CriminalATMJobTask)

_G.AutoFarm = false
local BlacklistATM = {} 

-- [[ CONFIG ]]
local DROP_POINT_CFRAME = CFrame.new(-2543.30786, 11.8932114, 4030.31909)

-- [[ LOGIC HELPERS ]]

local function GetMoneyBagCount()
    local count = 0
    local items = LP.Backpack:GetChildren()
    for _, tool in pairs(LP.Character:GetChildren()) do
        if tool:IsA("Tool") then table.insert(items, tool) end
    end
    for _, item in pairs(items) do
        if item.Name:match("MoneyBag") or item:GetAttribute("MoneyAmount") then
            count = count + (item:GetAttribute("MoneyAmount") or 1)
        end
    end
    return count
end

-- Fungsi Patroli: Datengin spawner biar ATM-nya "Muncul" (StreamingEnabled Bypass)
local function PatrolSpawners()
    print("Patroli Spawner: Mancing ATM muncul...")
    local Spawners = workspace.Game.Jobs.CriminalATMSpawners:GetChildren()
    
    for i, spawner in pairs(Spawners) do
        if not _G.AutoFarm then break end
        
        -- Kita teleport ke spawner setiap beberapa titik buat ngetrigger area
        -- Gak perlu semua, cukup lompat setiap 3 spawner biar hemat waktu
        if i % 3 == 0 then
            LP.Character:PivotTo(spawner.CFrame * CFrame.new(0, 50, 0)) -- TP di langit area spawner
            task.wait(0.8) -- Kasih waktu buat loading model
        end
        
        -- Cek kalau ada ATM yang muncul pas lagi patroli
        if spawner:FindFirstChild("ATM", true) then
            print("ATM Terdeteksi!")
            return -- Langsung balik ke loop utama buat ngerampok
        end
    end
end

local function GetTargetATM()
    local Spawners = workspace.Game.Jobs.CriminalATMSpawners:GetChildren()
    for _, spawner in pairs(Spawners) do
        local ATM = spawner:FindFirstChild("ATM", true) 
        if ATM and not BlacklistATM[ATM] then
            local Folder = ATM.Parent
            local state = Folder:GetAttribute("State")
            if state ~= CriminalConstants.ATMStates.Busted then
                local engaging = Folder:GetAttribute("EngagingPlayerId")
                if not engaging or engaging == 0 or engaging == LP.UserId then
                    return ATM 
                end
            end
        end
    end
    return nil
end

local function ProcessRob(TargetATM)
    local Folder = TargetATM.Parent
    LP.Character:PivotTo(TargetATM.CFrame * CFrame.new(0, 2, 4))
    task.wait(1.2) 
    
    local sStart = Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustStart, Folder)
    if sStart then
        local waitTime = CriminalUtil.GetATMBustTime(LP) or 5.2
        task.wait(waitTime + 0.6) 
        Remotes.invokeServer(CriminalConstants.RemoteFunctions.AttemptATMBustComplete, Folder)
        task.wait(5) -- Delay server sesuai request kamu
    else
        BlacklistATM[TargetATM] = true
        task.wait(0.5)
    end
end

-- [[ UI ]]
local MainTab = Window:CreateTab("Auto Farm", 4483362458)

MainTab:CreateToggle({
   Name = "Patrol & Rob Cycle",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoFarm = Value
      
      task.spawn(function()
          while _G.AutoFarm do
              local Hum = LP.Character:FindFirstChildOfClass("Humanoid")
              if Hum and Hum.SeatPart then Hum.Sit = false task.wait(0.3) end

              -- 1. CEK TAS
              if GetMoneyBagCount() >= 200 then
                  -- Setor
                  LP.Character:PivotTo(DROP_POINT_CFRAME * CFrame.new(0, 5, 0))
                  task.wait(0.5)
                  LP.Character:PivotTo(DROP_POINT_CFRAME)
                  task.wait(3)
                  pcall(function()
                      local DropObj = workspace.Game.Jobs:FindFirstChild("CriminalDropOffPoint") or workspace.Game.Jobs:FindFirstChild("CriminalDropOffPoints")
                      ATMJobTask.AttemptCompleteJob(DropObj)
                  end)
                  task.wait(2)
              end

              -- 2. CARI ATM
              local Target = GetTargetATM()
              if Target then
                  pcall(function() ProcessRob(Target) end)
              else
                  -- KALAU GAK ADA ATM: Patroli dulu buat ngetrigger StreamingEnabled
                  PatrolSpawners()
                  task.wait(2)
              end
              
              if not _G.AutoFarm then break end
          end
      end)
   end,
})
