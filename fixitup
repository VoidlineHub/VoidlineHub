-- [[ VOIDLINE HUB | FIX IT UP - V8.23 SPLIT WASH SYNC ]]

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "voidlinehub | Fix It Up",
   LoadingTitle = "private",
   LoadingSubtitle = "by bilzz",
   ConfigurationSaving = { Enabled = false }
})

-- // DATA & SETTINGS
local LP = game:GetService("Players").LocalPlayer
local bld = workspace.Map.FirstCity.Buildings:GetChildren()[19]
local moveable = workspace:FindFirstChild("MoveableParts")
local TeleportPos = CFrame.new(-573.336792, 3.84983015, -1595.71082, -1, -6.19937055e-07, -1.06341673e-08, -6.19937055e-07, 1, 9.22730351e-07, 1.06335953e-08, 9.22730351e-07, -1)

-- // FUNCTIONS
local function GetClosestVehicle()
    local closest = nil
    local dist = 35
    for _, v in pairs(workspace.Vehicles:GetChildren()) do
        local primary = v:FindFirstChild("DriveSeat") or v:FindFirstChildWhichIsA("BasePart", true)
        if primary and LP.Character:FindFirstChild("HumanoidRootPart") then
            local d = (LP.Character.HumanoidRootPart.Position - primary.Position).Magnitude
            if d < dist then dist = d; closest = v end
        end
    end
    return closest
end

-- // [ CORE AUTO-REPAIR ]
local function FullAutoCycle()
    local target = GetClosestVehicle()
    if not target then Rayfield:Notify({Title = "Error", Content = "Mobilnya mana?", Duration = 2}) return end
    
    local partsEvent = target:FindFirstChild("PartsEvent")
    local engineBay = target.Body:FindFirstChild("EngineBay")
    if not engineBay then return end

    -- 1. ABSEN ENGINEBAY (MEMORIZE)
    local engineMemory = {}
    for _, p in pairs(engineBay:GetChildren()) do
        engineMemory[p.Name] = true
    end

    -- 2. TELEPORT & BONGKAR
    target:PivotTo(TeleportPos)
    task.wait(0.5)
    partsEvent:FireServer("ReapplyPart", Instance.new("Model", nil))
    task.wait(0.2)
    
    for name, _ in pairs(engineMemory) do
        pcall(function() partsEvent:FireServer("RemovePart", name) end)
        task.wait(0.05)
    end
    task.wait(2.5)

    -- 3. MATCHMAKING & SPLIT ROUTING
    Rayfield:Notify({Title = "Matching", Content = "Routing Parts (AirIntake @ St2, Radiator @ St3)", Duration = 4})

    for _, part in pairs(moveable:GetChildren()) do
        if engineMemory[part.Name] then
            local name = part.Name
            
            -- [ STATION 3 ]
            if name == "Battery" then
                part:PivotTo(bld.Station3.BatteryCharger.Detector:GetPivot())
                task.wait(0.4); fireclickdetector(bld.Station3.BatteryCharger.Button.ClickDetector)

            elseif name == "EngineBlock" then
                part:PivotTo(bld.Station3:GetChildren()[3].Model:GetPivot())
                task.wait(0.4); fireclickdetector(bld.Station3:GetChildren()[3].Button.ClickDetector)

            elseif string.find(name, "Speed") or string.find(name, "CV") or name == "Transmission" then
                part:PivotTo(bld.Station3.GrindingMachine:GetPivot())
                task.wait(0.4)
                local cd = bld.Station3.GrindingMachine:FindFirstChildWhichIsA("ClickDetector", true)
                if cd then fireclickdetector(cd) end

            elseif name == "Radiator" then -- RADIATOR DI 3
                part:PivotTo(bld.Station3.PartsWasher.Faucet:GetPivot())
                task.wait(0.4)
                local cd = bld.Station3.PartsWasher.Faucet:FindFirstChildWhichIsA("ClickDetector", true)
                if cd then fireclickdetector(cd) end

            -- [ STATION 2 ]
            elseif name == "AirIntake" then -- AIR INTAKE DI 2
                -- Mencari PartsWasher di Station 2
                local washer2 = bld.Station2:FindFirstChild("PartsWasher")
                if washer2 then
                    part:PivotTo(washer2.Faucet:GetPivot())
                    task.wait(0.4)
                    fireclickdetector(washer2.Faucet.ClickDetector)
                end

            elseif name == "CylinderHead" then
                part:PivotTo(bld.Station2:GetChildren()[3].Model:GetPivot())
                task.wait(0.4); fireclickdetector(bld.Station2:GetChildren()[3].Button.ClickDetector)
            
            elseif name == "ExhaustManifold" then
                part:PivotTo(bld.Station2.GrindingMachine.Model:GetPivot())
                task.wait(0.4); fireclickdetector(bld.Station2.GrindingMachine.Button.ClickDetector)
            end
        end
    end

    -- 4. DELAY & INSTALL
    task.wait(23)
    for i = 1, 3 do
        for name, _ in pairs(engineMemory) do
            local item = moveable:FindFirstChild(name)
            if item then pcall(function() partsEvent:FireServer("ReapplyPart", item) end) end
        end
        task.wait(0.5); partsEvent:FireServer("ReapplyPart", Instance.new("Model", nil))
    end
    Rayfield:Notify({Title = "Success", Content = "Repair Split Complete!", Duration = 3})
end

-- // INTERFACE
local MainTab = Window:CreateTab("Mechanic", 4483362458)
MainTab:CreateButton({ Name = "🚀 START SPLIT AUTO (V8.23)", Callback = function() FullAutoCycle() end })
