-- TOGGLE UTAMA
FarmSection:AddToggle({
    Title = "Auto Farm (No-Delay Mode)",
    Default = false,
    Callback = function(Value)
        _G.AutoBrainrot = Value
        task.spawn(function()
            while _G.AutoBrainrot do
                pcall(function()
                    if KickCF and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                        local tw = TweenTo(KickCF)
                        if tw then tw.Completed:Wait() end
                        
                        Network.rev_Transformed:FireServer()
                        task.wait(0.01)
                        Network.rev_KickEvent:FireServer(0.9439757987856865)
                        Network.rev_KickZman:FireServer()
                        
                        task.wait(_G.DelayKick)
                        
                        Network.rev_KickCollect:FireServer()
                        task.wait(0.1)
                    end
                end)
                if not _G.AutoBrainrot then break end
                task.wait()
            end
        end)
    end
})

