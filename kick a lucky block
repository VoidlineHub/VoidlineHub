    ["normal"] = { Speed = 100, WaitKick = 0.2, LoopDelay = 1.5 },
    ["fast"] = { Speed = 250, WaitKick = 0.05, LoopDelay = 0.5 }
}

-- // 4. UTILITY FUNCTIONS (WAJIB ADA BIAR GAK ERROR NIL)
local function getTotalItems()
    local character = player.Character
    local backpack = player:FindFirstChild("Backpack")
    local count = 0
    if backpack then count = #backpack:GetChildren() end
    if character and character:FindFirstChildOfClass("Tool") then
        count = count + 1
    end
    return count
end

local function SmoothTween(targetCF, speed)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local distance = (hrp.Position - targetCF.Position).Magnitude
    local duration = distance / speed
    
    local info = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, info, {CFrame = targetCF})
    tween:Play()
    return tween
end

-- // 5. MAIN LOGIC
local function startAutoKick()
    task.spawn(function()
        print("VoidlineHub: Logic Started")
        while _G.AutoKick do
            local success, err = pcall(function()
                local cfg = ModeSettings[_G.SelectedMode]
                local character = player.Character
                local hrp = character and character:FindFirstChild("HumanoidRootPart")
                
                if hrp and safeZone then
                    local targetPos = safeZone.CFrame * CFrame.new(0, 3, 0)
                    
                    -- A. PERGI KE ZONE
                    if _G.SelectedMode == "very fast" then
                        hrp.CFrame = targetPos
                    else
                        local tw = SmoothTween(targetPos, cfg.Speed)
                        if tw then tw.Completed:Wait() end
                    end
                    
                    task.wait(0.1)
                    local initialCount = getTotalItems() -- Pemanggilan fungsi yang tadi bikin error
                    
                    -- B. KICK SEQUENCE
                    network.rev_Transformed:FireServer()
                    task.wait(cfg.WaitKick)
                    network.rev_KickEvent:FireServer(0.9691926166415215)
                    network.rev_KickZman:FireServer()
                    
                    -- C. SMART WAIT & PROTECTION
                    local timeout = 0
                    while _G.AutoKick and getTotalItems() <= initialCount and timeout < 8 do
                        task.wait(0.1)
                        timeout = timeout + 0.1
                        -- Anti-Mati Tsunami
                        if #wavesFolder:GetChildren() > 0 then
                            hrp.CFrame = targetPos 
                        end
                    end
                    
                    -- D. COLLECT
                    network.rev_KickCollect:FireServer()
                    task.wait(cfg.LoopDelay)
                end
            end)
            
            if not success then warn("Loop Error: " .. err) task.wait(1) end
            if not _G.AutoKick then break end
        end
    end)
end

-- // 2. Fungsi Logic Train (Taruh di atas UI atau di bagian Functions)
local function startAutoTrain()
    task.spawn(function()
        while _G.Train do
            pcall(function()
                -- Tembak remote barbel/power
                network.rev_TaviMishkal:FireServer()
            end)
            
            -- Gunakan task.wait yang nilainya selalu update dari Slider
            task.wait(_G.TrainInterval)
            
            if not _G.Train then break end
        end
    end)
end

local function startAutoClickBonus()
    task.spawn(function()
        while _G.AutoClickBonus do
            pcall(function()
                local gui = player.PlayerGui:FindFirstChild("KickUpgrades")
                if gui then
                    -- Scan semua anak di dalam KickUpgrades
                    for _, child in pairs(gui:GetChildren()) do
                        -- Cari yang namanya "Bonus" (atau sesuaikan kalau ada nama spesifik)
                        -- Kita cek juga apakah dia tombol (TextButton/ImageButton) dan lagi kelihatan
                        if child.Name:find("Bonus") and (child:IsA("TextButton") or child:IsA("ImageButton")) and child.Visible then
                            -- Simulasi Klik pakai getconnections biar instan tembus ke fungsi aslinya
                            for _, connection in pairs(getconnections(child.MouseButton1Click)) do
                                connection:Fire()
                            end
                            -- Opsional: kalau gamenya butuh VirtualUser buat nekan posisi
                            -- VirtualUser:ClickButton1(Vector2.new(0,0)) 
                        end
                    end
                end
            end)
            task.wait(0.1) -- Jeda scan biar gak bikin FPS drop karena looping ratusan anak
            if not _G.AutoClickBonus then break end
        end
    end)
end

