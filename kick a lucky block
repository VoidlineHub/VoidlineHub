local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

-- // 2. VARIABLES
local player = Players.LocalPlayer
local wavesFolder = workspace:WaitForChild("Waves")
local safeZone = workspace:WaitForChild("Areas"):WaitForChild("KickReady")
local network = ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Packages"):WaitForChild("Network")

-- // 3. GLOBALS & CONFIG
_G.AutoKick = false
_G.SelectedMode = "normal"

local ModeSettings = {
    ["normal"] = { Speed = 150, WaitKick = 0.2, LoopDelay = 1.5 },
    ["fast"] = { Speed = 350, WaitKick = 0.05, LoopDelay = 0.5 },
    ["very fast"] = { Speed = 1000, WaitKick = 0.01, LoopDelay = 0.01 }
}

-- // 4. UTILITY FUNCTIONS (WAJIB ADA BIAR GAK ERROR NIL)
local function getTotalItems()
    local character = player.Character
    local backpack = player:FindFirstChild("Backpack")
    local count = 0
    if backpack then count = #backpack:GetChildren() end
    if character and character:FindFirstChildOfClass("Tool") then
        count = count + 1
    end
    return count
end

local function SmoothTween(targetCF, speed)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local distance = (hrp.Position - targetCF.Position).Magnitude
    local duration = distance / speed
    
    local info = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, info, {CFrame = targetCF})
    tween:Play()
    return tween
end

-- // 5. MAIN LOGIC
local function startAutoKick()
    task.spawn(function()
        print("VoidlineHub: Logic Started")
        while _G.AutoKick do
            local success, err = pcall(function()
                local cfg = ModeSettings[_G.SelectedMode]
                local character = player.Character
                local hrp = character and character:FindFirstChild("HumanoidRootPart")
                
                if hrp and safeZone then
                    local targetPos = safeZone.CFrame * CFrame.new(0, 3, 0)
                    
                    -- A. PERGI KE ZONE
                    if _G.SelectedMode == "very fast" then
                        hrp.CFrame = targetPos
                    else
                        local tw = SmoothTween(targetPos, cfg.Speed)
                        if tw then tw.Completed:Wait() end
                    end
                    
                    task.wait(0.1)
                    local initialCount = getTotalItems() -- Pemanggilan fungsi yang tadi bikin error
                    
                    -- B. KICK SEQUENCE
                    network.rev_Transformed:FireServer()
                    task.wait(cfg.WaitKick)
                    network.rev_KickEvent:FireServer(0.9691926166415215)
                    network.rev_KickZman:FireServer()
                    
                    -- C. SMART WAIT & PROTECTION
                    local timeout = 0
                    while _G.AutoKick and getTotalItems() <= initialCount and timeout < 8 do
                        task.wait(0.1)
                        timeout = timeout + 0.1
                        -- Anti-Mati Tsunami
                        if #wavesFolder:GetChildren() > 0 then
                            hrp.CFrame = targetPos 
                        end
                    end
                    
                    -- D. COLLECT
                    network.rev_KickCollect:FireServer()
                    task.wait(cfg.LoopDelay)
                end
            end)
            
            if not success then warn("Loop Error: " .. err) task.wait(1) end
            if not _G.AutoKick then break end
        end
    end)
end

